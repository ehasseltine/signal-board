---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  dateStr?: string;
  totalStories?: number;
  sourcesReporting?: number;
}

const { title, description = 'Daily news analysis from 275 sources across the political spectrum, across borders, and across languages. See what no single outlet can show you.', dateStr, totalStories, sourcesReporting } = Astro.props;

const siteUrl = 'https://www.elisehasseltine.com/signal-board';
const ogImage = `${siteUrl}/og-image.png`;
const pageTitle = `Signal Board - ${title}`;
const canonicalUrl = `${siteUrl}/${title === 'Today' ? 'today/' : title === 'About' ? 'about/' : title === 'Archive' ? 'archive/' : ''}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={description}>

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/signal-board/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/signal-board/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/signal-board/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/signal-board/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/signal-board/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Signal Board">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={pageTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl}>

  <!-- JSON-LD Structured Data -->
  {title === 'Today' && dateStr && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "headline": pageTitle,
      "description": description,
      "image": ogImage,
      "datePublished": dateStr,
      "dateModified": dateStr,
      "author": {
        "@type": "Person",
        "name": "Elise Hasseltine",
        "url": "https://www.elisehasseltine.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Signal Board",
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon-192.png`
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
      },
      "isAccessibleForFree": true,
      ...(totalStories ? { "about": `Analysis of ${totalStories} articles from ${sourcesReporting || 275} sources` } : {})
    })} />
  )}
  {title === 'About' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Signal Board",
      "description": description,
      "url": canonicalUrl,
      "mainEntity": {
        "@type": "WebApplication",
        "name": "Signal Board",
        "applicationCategory": "News Analysis",
        "operatingSystem": "Web",
        "description": "Daily news analysis from 275 sources across the political spectrum, across borders, and across languages.",
        "author": {
          "@type": "Person",
          "name": "Elise Hasseltine",
          "url": "https://www.elisehasseltine.com"
        }
      }
    })} />
  )}
  {title !== 'Today' && title !== 'About' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Signal Board",
      "url": siteUrl,
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Elise Hasseltine",
        "url": "https://www.elisehasseltine.com"
      }
    })} />
  )}

  <!-- Fonts — consolidated to 4 families for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Abril+Fatface&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Caveat:wght@400;700&family=Inter:wght@400;500;600&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Abril+Fatface&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Caveat:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<a href="#main-content" class="skip-nav">Skip to content</a>

<div id="progress" role="presentation"></div>

<slot />

<script>
  // Intersection Observer for scroll reveals
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('v'); });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.r').forEach(el => obs.observe(el));

  setTimeout(() => {
    document.querySelectorAll('.masthead .r').forEach(el => el.classList.add('v'));
  }, 200);

  const bar = document.getElementById('progress');
  window.addEventListener('scroll', () => {
    bar.style.width = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100 + '%';
  }, { passive: true });

  let scrolled = false;
  window.addEventListener('scroll', () => {
    if (!scrolled) { scrolled = true; const c = document.querySelector('.scroll-cue'); if (c) c.style.opacity = '0'; }
  }, { passive: true });

  document.querySelectorAll('.summary-card').forEach(card => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(card.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Scroll depth tracking — fires once per threshold
  const depthMarks = [25, 50, 75, 100];
  const depthFired = new Set();
  window.addEventListener('scroll', () => {
    const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
    depthMarks.forEach(m => {
      if (pct >= m && !depthFired.has(m)) {
        depthFired.add(m);
        if (typeof gtag === 'function') gtag('event', 'scroll_depth', { depth: m });
        console.log(`[Signal Board] Scroll depth: ${m}%`);
      }
    });
  }, { passive: true });
</script>

</body>
</html>
