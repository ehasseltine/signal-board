const rAF = fn => requestAnimationFrame(fn);
const lerp = (a, b, t) => a + (b - a) * t;
const easeOut = t => 1 - Math.pow(1 - t, 3);
const easeOutQuart = t => 1 - Math.pow(1 - t, 4);

/* ═════════════════════════════════════════
   1. GAME OF LIFE — hero
═════════════════════════════════════════ */
(function initGoL() {
  const canvas = document.getElementById('gol-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const SZ = 13;
  const COLS = ['#FF2D55','#FF9500','#30D158','#0A84FF','#BF5AF2','#FFD60A'];
  let W, H, cols, rows, grid, next, colors;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cols = Math.ceil(W/SZ)+1; rows = Math.ceil(H/SZ)+1;
    grid = new Uint8Array(cols*rows); next = new Uint8Array(cols*rows);
    colors = new Uint8Array(cols*rows);
    for (let i=0;i<grid.length;i++) { grid[i]=Math.random()<0.2?1:0; colors[i]=Math.floor(Math.random()*6); }
  }

  function step() {
    for (let r=0;r<rows;r++) for (let c=0;c<cols;c++) {
      let n=0, idx=r*cols+c;
      for (let dr=-1;dr<=1;dr++) for (let dc=-1;dc<=1;dc++) {
        if(!dr&&!dc) continue;
        n+=grid[((r+dr+rows)%rows)*cols+((c+dc+cols)%cols)];
      }
      if (grid[idx]) next[idx]=(n===2||n===3)?1:0;
      else { next[idx]=n===3?1:0; if(n===3) colors[idx]=Math.floor(Math.random()*6); }
    }
    [grid,next]=[next,grid];
  }

  let fr=0;
  function draw() {
    ctx.clearRect(0,0,W,H);
    for (let r=0;r<rows;r++) for (let c=0;c<cols;c++) {
      if (!grid[r*cols+c]) continue;
      ctx.globalAlpha=0.48; ctx.fillStyle=COLS[colors[r*cols+c]];
      ctx.beginPath(); ctx.roundRect(c*SZ+1,r*SZ+1,SZ-2,SZ-2,2); ctx.fill();
    }
    ctx.globalAlpha=1;
    const g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0,'rgba(8,8,14,0.35)'); g.addColorStop(0.45,'rgba(8,8,14,0.55)'); g.addColorStop(1,'rgba(8,8,14,0.96)');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
    fr++; if(fr%4===0) step();
    rAF(draw);
  }
  resize(); draw();
  window.addEventListener('resize', resize);

  // Count-ups
  const io = new IntersectionObserver(entries => entries.forEach(e => {
    if(!e.isIntersecting) return; io.unobserve(e.target);
    const target=parseInt(e.target.dataset.target), dur=1400, start=performance.now();
    function tick(now) {
      const t=Math.min(1,(now-start)/dur), ease=easeOutQuart(t);
      e.target.textContent=Math.round(ease*target).toLocaleString();
      if(t<1) rAF(tick);
    }
    rAF(tick);
