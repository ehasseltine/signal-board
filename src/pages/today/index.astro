    'Geopolitics': { dot: '#084C61', bg: 'rgba(215,255,26,0.18)' },
    'Governance': { dot: '#FDB833', bg: 'rgba(215,255,26,0.18)' },
    'Politics': { dot: '#5D5179', bg: 'rgba(215,255,26,0.18)' },
