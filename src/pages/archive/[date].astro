---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDailyData, listDailyDates } from '../../lib/data';
import {
  selectDailyThread,
  selectDailyGap,
  selectMeanwhile
} from '../../lib/storySelection';
import type { MegaStory } from '../../lib/storySelection';

interface Props {
  date: string;
}

export async function getStaticPaths() {
  const dates = listDailyDates();
  return dates.map(date => ({
    params: { date },
  }));
}

const { date } = Astro.params;
const pipelineData = loadDailyData(date!);

if (!pipelineData) {
  return Astro.redirect('/signal-board/archive/');
}

// Extract mega_stories — where the real analysis lives
const megaStories: MegaStory[] = pipelineData.mega_stories || [];
const localRegionalSynthesis: string = pipelineData.local_regional_synthesis || '';
const localRegionalExamples: any[] = pipelineData.local_regional_examples || [];

// Select stories
const threadStory = selectDailyThread(megaStories);
const gapStory = selectDailyGap(megaStories, threadStory?.title || '');
const meanwhileStory = selectMeanwhile(
  megaStories,
  localRegionalSynthesis,
  localRegionalExamples,
  threadStory?.title || '',
  gapStory?.title || ''
);

const dateStr = pipelineData.date || date;
const summary = pipelineData.summary || {};
const totalStories = summary.total_stories || 0;
const sourcesReporting = summary.sources_reporting || 0;
const crossDomain = summary.cross_domain || 0;
const crossDomainPct = summary.cross_domain_pct || 0;

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
---

<BaseLayout title={`Archive - ${dateStr}`}>

<div class="masthead-wrap">
  <div class="wrap">
    <div class="masthead">
      <div class="r">
        <div class="display masthead-title">SIGNAL</div>
        <div class="display masthead-title">BOARD</div>
      </div>
      <span class="masthead-date r d1">{dateStr}</span>
      <h1 class="masthead-hook r d2">
        {sourcesReporting} sources published {totalStories} stories this day.
      </h1>
      <p class="masthead-sub r d3">
        {crossDomain} crossed domain boundaries. Here's what the picture looked like.
      </p>
    </div>
  </div>
</div>

<!-- DAILY THREAD -->
{threadStory && (
<div id="thread">
<div class="wrap">
  <div class="section">
    <span class="section-label r">The Daily Thread</span>
    <h2 class="headline r d1">{threadStory.title}</h2>
    {threadStory.synthesis && (
      <p class="body r d2" style="margin-top: 28px; font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8;" set:html={escapeHtml(threadStory.synthesis)} />
    )}
    {threadStory.crossSpectrum && (
      <div class="r" style="margin-top: 24px; border-left: 4px solid var(--red); padding: 16px 20px; background: rgba(27, 42, 74, 0.04); border-radius: 0 8px 8px 0;">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8;" set:html={escapeHtml(threadStory.crossSpectrum)} />
      </div>
    )}
    {threadStory.whyThisMatters && (
      <p class="body r" style="margin-top: 24px; font-style: italic;" set:html={escapeHtml(threadStory.whyThisMatters)} />
    )}
  </div>
</div>
</div>
)}

<!-- DAILY GAP -->
{gapStory && (
<div id="gap" class="navy">
<div class="wrap">
  <div class="section">
    <span class="section-label r">The Daily Gap</span>
    <h2 class="headline r d1">{gapStory.title}</h2>
    {gapStory.synthesis && (
      <p class="body r d2" style="margin-top: 28px; font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8; color: var(--on-navy-dim);" set:html={escapeHtml(gapStory.synthesis)} />
    )}
    {gapStory.crossSpectrum && (
      <div class="r" style="margin-top: 24px; border-left: 4px solid var(--red); padding: 16px 20px; background: rgba(255, 255, 255, 0.06); border-radius: 0 8px 8px 0;">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--on-navy-dim);" set:html={escapeHtml(gapStory.crossSpectrum)} />
      </div>
    )}
    {gapStory.whyThisMatters && (
      <p class="body r" style="margin-top: 24px; font-style: italic; color: var(--cream);" set:html={escapeHtml(gapStory.whyThisMatters)} />
    )}
  </div>
</div>
</div>
)}

<!-- MEANWHILE -->
{meanwhileStory && (
<div id="meanwhile" style="background: #EFF5EE;">
<div class="wrap">
  <div class="section">
    <span class="section-label section-label-green r">Meanwhile</span>
    <h2 class="headline r d1">{meanwhileStory.title}</h2>
    {meanwhileStory.synthesis && (
      <p class="body r d2" style="margin-top: 28px; font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8;" set:html={escapeHtml(meanwhileStory.synthesis)} />
    )}
    {meanwhileStory.insights && meanwhileStory.insights.length > 0 && meanwhileStory.insights.map((insight: string) => (
      <div class="r" style="margin-top: 20px; padding: 16px 20px; background: rgba(45, 138, 78, 0.06); border-radius: 8px; border-left: 4px solid var(--green);">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8;" set:html={escapeHtml(insight)} />
      </div>
    ))}
  </div>
</div>
</div>
)}

<!-- CLOSE -->
<div class="close-section">
  <div class="wrap">
    <p class="body r" style="color: var(--on-navy-dim);">
      <a href="/signal-board/archive/" style="color: var(--red); text-decoration: underline;">Back to archive</a>
    </p>
  </div>
</div>

</BaseLayout>
