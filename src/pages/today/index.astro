    'Washington Post': { country: 'US', geo: 'national', tier: 'national' },
    'AP News': { country: 'US', geo: 'national', tier: 'national' },
    'Reuters': { country: 'UK', geo: 'international', tier: 'national' },
    'Bloomberg': { country: 'US', geo: 'national', tier: 'national' },
    'NBC News': { country: 'US', geo: 'national', tier: 'national' },
    'ABC News': { country: 'US', geo: 'national', tier: 'national' },
    'NPR': { country: 'US', geo: 'national', tier: 'national' },
    'Fox News': { country: 'US', geo: 'national', tier: 'national' },
    'CNBC': { country: 'US', geo: 'national', tier: 'national' },
    'The Hill': { country: 'US', geo: 'national', tier: 'national' },
    'The Atlantic': { country: 'US', geo: 'national', tier: 'analysis' },
    'Colorado Sun': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Texas Tribune': { country: 'US', geo: 'local', tier: 'local-regional' },
    'MinnPost': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Oregon Public Broadcasting': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Wisconsin Examiner': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Source NM': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Honolulu Civil Beat': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Post and Courier': { country: 'US', geo: 'local', tier: 'local-regional' },
    'Inside Climate News': { country: 'US', geo: 'national', tier: 'specialist' },
    'Mother Jones': { country: 'US', geo: 'national', tier: 'specialist' },
    'The Marshall Project': { country: 'US', geo: 'national', tier: 'specialist' },
    'Military Times': { country: 'US', geo: 'national', tier: 'specialist' },
    'Lawfare': { country: 'US', geo: 'national', tier: 'specialist' },
    'Hechinger Report': { country: 'US', geo: 'national', tier: 'specialist' },
    'Naked Capitalism': { country: 'US', geo: 'national', tier: 'analysis' },
    'Heritage Foundation': { country: 'US', geo: 'national', tier: 'analysis' },
    'RealClearPolitics': { country: 'US', geo: 'national', tier: 'analysis' },
    'Arab American News': { country: 'US', geo: 'local', tier: 'specialist' },
    'The Advocate': { country: 'US', geo: 'national', tier: 'specialist' },
    'Indian Country Today': { country: 'US', geo: 'national', tier: 'specialist' },
    'El Diario NY': { country: 'US', geo: 'local', tier: 'specialist' },
    'The Root': { country: 'US', geo: 'national', tier: 'specialist' },
    'Atlanta Black Star': { country: 'US', geo: 'national', tier: 'specialist' },
    'The Grio': { country: 'US', geo: 'national', tier: 'specialist' },
    'AsAmNews': { country: 'US', geo: 'national', tier: 'specialist' },
    'The Forward': { country: 'US', geo: 'national', tier: 'specialist' },
    'National Catholic Reporter': { country: 'US', geo: 'national', tier: 'specialist' },
    'Religion News Service': { country: 'US', geo: 'national', tier: 'specialist' },
    'Breitbart': { country: 'US', geo: 'national', tier: 'national' },
    'Daily Wire': { country: 'US', geo: 'national', tier: 'national' },
    'Washington Times': { country: 'US', geo: 'national', tier: 'national' },
  };
  return GEO_MAP[sourceName] || null;
}

---

<BaseLayout title="Today" description={`${dateStr}: Signal Board read ${totalMonitoredSources} sources and found ${totalStories} stories. ${editorial?.accessible_headline || editorial?.headline || 'See what the picture looks like today.'}`} dateStr={dateStr} totalStories={totalStories} sourcesReporting={sourcesReporting}>

<!-- MASTHEAD — NAVY -->
<header class="masthead-wrap" role="banner">
  <!-- Decorative constellation — represents interconnected sources -->
  <svg class="masthead-constellation" viewBox="0 0 800 600" fill="none" aria-hidden="true" style="position: absolute; top: 0; right: 0; width: 55%; height: 100%; opacity: 0.08; pointer-events: none;">
    <!-- Connection lines -->
    <line x1="120" y1="80" x2="340" y2="160" stroke="var(--cream)" stroke-width="1"/>
    <line x1="340" y1="160" x2="580" y2="120" stroke="var(--cream)" stroke-width="1"/>
    <line x1="580" y1="120" x2="700" y2="280" stroke="var(--cream)" stroke-width="1"/>
    <line x1="340" y1="160" x2="260" y2="340" stroke="var(--cream)" stroke-width="1"/>
    <line x1="260" y1="340" x2="480" y2="380" stroke="var(--cream)" stroke-width="1"/>
    <line x1="480" y1="380" x2="700" y2="280" stroke="var(--cream)" stroke-width="1"/>
    <line x1="480" y1="380" x2="620" y2="500" stroke="var(--cream)" stroke-width="1"/>
    <line x1="260" y1="340" x2="140" y2="480" stroke="var(--cream)" stroke-width="1"/>
    <line x1="140" y1="480" x2="380" y2="520" stroke="var(--cream)" stroke-width="1"/>
    <line x1="380" y1="520" x2="620" y2="500" stroke="var(--cream)" stroke-width="1"/>
    <line x1="580" y1="120" x2="480" y2="380" stroke="var(--cream)" stroke-width="0.5"/>
    <line x1="120" y1="80" x2="260" y2="340" stroke="var(--cream)" stroke-width="0.5"/>
    <!-- Nodes — sources -->
    <circle cx="120" cy="80" r="4" fill="var(--red)"/>
    <circle cx="340" cy="160" r="6" fill="var(--cream)"/>
    <circle cx="580" cy="120" r="5" fill="var(--cream)"/>
    <circle cx="700" cy="280" r="4" fill="var(--red)"/>
    <circle cx="260" cy="340" r="7" fill="var(--cream)"/>
    <circle cx="480" cy="380" r="5" fill="var(--cream)"/>
    <circle cx="620" cy="500" r="4" fill="var(--red)"/>
    <circle cx="140" cy="480" r="3" fill="var(--cream)"/>
    <circle cx="380" cy="520" r="5" fill="var(--cream)"/>
    <!-- Smaller orbiting dots -->
    <circle cx="200" cy="110" r="2" fill="var(--cream)" opacity="0.5"/>
    <circle cx="460" cy="140" r="2" fill="var(--cream)" opacity="0.5"/>
    <circle cx="640" cy="200" r="2" fill="var(--cream)" opacity="0.5"/>
    <circle cx="360" cy="260" r="2" fill="var(--cream)" opacity="0.5"/>
    <circle cx="540" cy="440" r="2" fill="var(--cream)" opacity="0.5"/>
    <circle cx="200" cy="420" r="2" fill="var(--cream)" opacity="0.5"/>
  </svg>
  <div class="wrap" style="position: relative; z-index: 1;">
    <nav aria-label="Signal Board navigation" style="padding-top: 24px; display: flex; justify-content: flex-end; gap: 24px;">
      <a href="/signal-board/about/" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">About</a>
      <a href="/signal-board/archive/" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">Archive</a>
      <a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">Subscribe</a>
    </nav>
    <div class="masthead">
      <div class="r">
        <div class="display masthead-title">SIGNAL</div>
        <div class="display masthead-title">BOARD</div>
      </div>
      <span class="masthead-date r d1">{dateStr}</span>
      <h1 class="masthead-hook r d2">
        {editorial?.accessible_headline || editorial?.headline || `Today, ${totalMonitoredSources} sources published ${totalStories} stories. When you see them together, a picture emerges.`}
      </h1>
      <p class="masthead-sub r d3">
        {editorial?.subheadline || `${crossDomain} stories crossed domain boundaries, ${crossDomainPct}% of everything we read. That's where the connections live.`}
      </p>
      <div class="scroll-cue" aria-hidden="true">
        <span>scroll</span>
        <svg width="18" height="10" viewBox="0 0 18 10" fill="none">
          <path d="M2,2 L9,8 L16,2" stroke="var(--cream)" stroke-width="1.5" stroke-linecap="round" opacity="0.35"/>
        </svg>
      </div>
    </div>
  </div>
  <!-- Constellation lines bleeding below the navy masthead -->
  <svg class="constellation-bleed" viewBox="0 0 600 120" fill="none" aria-hidden="true">
    <line x1="100" y1="0" x2="200" y2="80" stroke="var(--ink)" stroke-width="1"/>
    <line x1="200" y1="80" x2="400" y2="40" stroke="var(--ink)" stroke-width="1"/>
    <line x1="400" y1="40" x2="550" y2="100" stroke="var(--ink)" stroke-width="0.5"/>
    <circle cx="200" cy="80" r="3" fill="var(--red)" opacity="0.3"/>
    <circle cx="400" cy="40" r="2" fill="var(--ink)" opacity="0.2"/>
  </svg>
</header>

<main id="main-content" style="position: relative; z-index: 1;">

<!-- SUMMARY CARDS — CREAM -->
<div class="wrap-wide" style="padding-top: clamp(48px, 7vw, 80px); padding-bottom: clamp(24px, 4vw, 40px);">
  <div class="summary-grid r">

    {threadStory && (
    <a href="#thread" class="summary-card" style="text-decoration: none; color: inherit;">
      <div class="card-label">
        <svg width="18" height="14" viewBox="0 0 22 18" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <line x1="1" y1="4" x2="21" y2="4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="4" y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/>
          <line x1="7" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.25"/>
        </svg>The Daily Thread
      </div>
      <div class="card-stat">{threadStory.articleCount}</div>
      <div class="stat-annotation stat-annotation-red">articles from {threadStory.sourceCount} sources</div>
      <div class="card-hook">{threadStory.title}</div>
      <span class="card-arrow">Read &darr;</span>
    </a>
    )}

    {gapStory && (
    <a href="#gap" class="summary-card summary-card-teal" style="text-decoration: none; color: inherit;">
      <div class="card-label card-label-teal">
        <svg width="16" height="14" viewBox="0 0 20 18" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <rect x="1" y="1" width="6" height="16" rx="1" fill="currentColor"/>
          <rect x="13" y="1" width="6" height="16" rx="1" fill="currentColor" opacity="0.25"/>
        </svg>The Daily Gap
      </div>
      <div class="card-stat card-stat-teal">{gapStory.sourceCount}</div>
      <div class="stat-annotation stat-annotation-teal">sources covering what others miss</div>
      <div class="card-hook">{gapStory.title}</div>
      <span class="card-arrow">Read &darr;</span>
    </a>
    )}

    <a href="#meanwhile" class="summary-card summary-card-green" style="text-decoration: none; color: inherit;">
      <div class="card-label card-label-green">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <circle cx="10" cy="10" r="4" fill="currentColor"/>
          <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        </svg>Meanwhile
      </div>
      <div class="card-stat card-stat-green">{cooperation?.total_cooperation_stories || '—'}</div>
      <div class="stat-annotation stat-annotation-green">{cooperation ? `stories of people showing up (${cooperation.cooperation_rate}%)` : 'who showed up today'}</div>
      <div class="card-hook">One in four stories today showed people showing up for each other.</div>
      <span class="card-arrow">Read &darr;</span>
    </a>

  </div>
</div>

<!-- ================================================================ -->
<!-- THE DAILY THREAD — CREAM BACKGROUND                              -->
<!-- ================================================================ -->
{threadStory && (
<article id="thread" class="section-world thread-world" aria-label="The Daily Thread">
<div class="wrap">
  <div style="padding: 48px 0 0;">
    <span class="section-label r">
      <svg class="cat-icon" width="22" height="18" viewBox="0 0 22 18" fill="none"><line x1="1" y1="4" x2="21" y2="4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="4" y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/><line x1="7" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.25"/></svg>
      The Daily Thread
    </span>
    <h2 class="headline headline-thread r d1">{threadStory.title}</h2>

    {threadStory.changeDescription && (
      <p class="r d1" style="font-family: 'Caveat', cursive; font-size: clamp(18px, 2vw, 22px); color: var(--red-accessible); margin-top: 8px;">
        {threadStory.changeDescription}
      </p>
    )}
  </div>

  <!-- COVERAGE METER — the data visualization unique to Signal Board -->
  <div class="r d2" style="margin-top: 32px; padding: 28px 0; border-top: 1px solid rgba(27,42,74,0.08); border-bottom: 1px solid rgba(27,42,74,0.08);">
    <div style="display: flex; align-items: center; gap: 24px; flex-wrap: wrap;">
      <div>
        <div class="display" style="font-size: clamp(48px, 7vw, 72px); line-height: 1; color: var(--red);">{threadStory.articleCount}</div>
        <div class="stat-annotation stat-annotation-red" style="margin-top: 6px;">articles across {threadStory.sourceCount} sources</div>
      </div>
      <div style="flex: 1; min-width: 200px;">
        <div style="height: 12px; background: rgba(27,42,74,0.08); border-radius: 6px; overflow: hidden;">
          <div style={`height: 100%; width: ${Math.min(100, Math.round((threadStory.articleCount / Math.max(totalStories, 1)) * 100))}%; background: var(--yellow); border-radius: 6px;`}></div>
        </div>
        <div style="display: flex; justify-content: space-between; margin-top: 6px;">
          <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--ink-mid); font-weight: 500;">
            {Math.round((threadStory.articleCount / Math.max(totalStories, 1)) * 100)}% of today's coverage
          </span>
          <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--ink-light);">
            {threadStory.sourceCount} sources &middot; {totalStories} total stories
          </span>
        </div>
        {Object.keys(threadStory.sourceTiers).length > 0 && (
        <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;">
          {Object.entries(threadStory.sourceTiers).map(([tier, count]) => (
            <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light); background: var(--ink-faint); padding: 3px 8px; border-radius: 12px;">
              {tierLabel(tier)}: {count}
            </span>
          ))}
        </div>
        )}
      </div>
    </div>
  </div>

  <!-- SYNTHESIS -->
  {threadStory.synthesis && (
  <div style="padding: 28px 0 0;">
    <div class="r">
      <p class="body r d2" style="font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8; margin-bottom: 0;" set:html={escapeHtml(threadStory.synthesis)} />
    </div>
  </div>
  )}

  <!-- CROSS-SPECTRUM — framing exhibit -->
  {threadStory.crossSpectrum && (
  <div style="padding: 32px 0 0;">
    <span class="section-label r" style="font-size: 13px; margin-bottom: 20px; display: block;">How outlets told it differently</span>
    <div class="r" style="display: flex; flex-direction: column; gap: 0;">
      {threadStory.crossSpectrum.split(/(?<=\.)\s+/).filter((s: string) => s.trim().length > 10).map((sentence: string, i: number) => {
        const tierMatch = sentence.match(/^(National|International|Local|Specialist|Military|Conservative|Progressive|Analysis)/i);
        const tierName = tierMatch ? tierMatch[1] : `Perspective ${i + 1}`;
        const content = tierMatch ? sentence.replace(tierMatch[0], '').replace(/^[-\s]*(?:focused|oriented|leaning)?\s*(?:outlets?|sources?|media|press|coverage)?\s*/i, '').replace(/^[,.:]\s*/, '') : sentence;
        return (
        <div class="framing-row" data-tier={tierName}>
          <div class="framing-label">{tierName}</div>
          <div class="framing-content">{content.trim()}</div>
        </div>
        );
      })}
    </div>
  </div>
  )}
</div>

<!-- WHY THIS MATTERS — warm editorial wash -->
{threadStory.whyThisMatters && (
<div class="editorial-wash r" style="margin-top: 32px; overflow: hidden;">
  <div class="wrap">
    <p style="font-family: 'Lora', serif; font-style: italic; font-size: clamp(19px, 2.2vw, 26px); line-height: 1.7; color: var(--ink); max-width: 680px;" set:html={escapeHtml(threadStory.whyThisMatters)} />
  </div>
</div>
)}

<div class="wrap">
  <!-- WATCH FOR (pipeline) -->
  {threadStory.watchFor && (
  <div style="padding: 28px 0 0;">
    <div class="r callout-wash callout-wash-yellow">
      <div class="watch-for-card" style="border-left: 4px solid var(--yellow); padding: 14px 18px; background: rgba(255, 210, 63, 0.13); border-radius: 0 8px 8px 0;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--yellow-accessible); font-weight: 600; display: block; margin-bottom: 8px;">What to watch for</span>
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--ink); margin: 0;" set:html={escapeHtml(threadStory.watchFor)} />
      </div>
    </div>
  </div>
  )}

  <!-- THREAD TO WATCH (editorial) -->
  {editorial?.thread_to_watch && (
  <div style="padding: 16px 0 0;">
    <div class="r callout-wash callout-wash-yellow">
      <div style="border-left: 4px solid var(--yellow); padding: 14px 18px; background: rgba(255, 210, 63, 0.13); border-radius: 0 8px 8px 0;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--yellow-accessible); font-weight: 600; display: block; margin-bottom: 8px;">Thread to watch</span>
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--ink); margin: 0;" set:html={escapeHtml(editorial.thread_to_watch)} />
      </div>
    </div>
  </div>
  )}

  <!-- SOURCES -->
  {threadStory.sourcesSample.length > 0 && (
  <div style="padding: 24px 0 48px;">
    <div class="coverage-label r">Sources reporting</div>
    <div class="coverage-grid r">
      {threadStory.sourcesSample.slice(0, 8).map(sourceName => {
        const geo = getSourceGeo(sourceName);
        return (
        <div class="coverage-card" data-tier={geo?.tier || ''} data-geo={geo?.geo || ''}>
          <div class="coverage-name">{sourceName}{geo && geo.country !== 'US' && <span class="coverage-country">{geo.country}</span>}</div>
          {getSourceContext(sourceName) && (
            <div class="coverage-type">{getSourceContext(sourceName)}</div>
          )}
        </div>
        );
      })}
    </div>
  </div>
  )}
</div>
</article>
)}

<!-- Angled divider: cream → navy -->
<div class="section-divider" aria-hidden="true" style="background: var(--cream);">
  <svg viewBox="0 0 1440 72" preserveAspectRatio="none" fill="none">
    <polygon points="0,0 1440,0 1440,24 0,0" fill="var(--cream)"/>
    <polygon points="0,0 1440,24 1440,72 0,72" fill="var(--ink)"/>
  </svg>
</div>

<!-- ================================================================ -->
<!-- THE DAILY GAP — NAVY HEADER + TEAL WASH BODY                     -->
<!-- ================================================================ -->
{gapStory && (
<!-- Gap header strip — navy -->
<div class="navy" style="padding-bottom: 0; margin-top: -1px;">
<div class="wrap">
  <div style="padding: 48px 0 0;">
    <span class="section-label r" style="color: var(--teal);">
      <svg class="cat-icon" width="20" height="18" viewBox="0 0 20 18" fill="none"><rect x="1" y="1" width="6" height="16" rx="1" fill="currentColor"/><rect x="13" y="1" width="6" height="16" rx="1" fill="currentColor" opacity="0.25"/></svg>
      The Daily Gap
    </span>
    <h2 class="headline headline-gap r d1" style="color: var(--cream); font-size: clamp(28px, 4.5vw, 52px);">{gapStory.title}</h2>

    {gapStory.changeDescription && (
      <p class="r d1" style="font-family: 'Caveat', cursive; font-size: clamp(18px, 2vw, 22px); color: var(--teal); margin-top: 8px;">
        {gapStory.changeDescription}
      </p>
    )}

    <!-- Article + source count -->
    <div class="r d2" style="margin-top: 24px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; padding-bottom: 40px;">
      <div class="display" style="font-size: clamp(40px, 6vw, 64px); line-height: 1; color: var(--teal);">{gapStory.articleCount}</div>
      <div class="stat-annotation" style="color: var(--on-navy-dim);">
        articles from <strong style="color: var(--teal); font-weight: 700;">{gapStory.sourceCount} sources</strong> covering what others missed
      </div>
    </div>
  </div>
</div>
</div>

<!-- Angled divider: navy → teal wash -->
<div class="section-divider" aria-hidden="true" style="background: var(--teal-wash);">
  <svg viewBox="0 0 1440 72" preserveAspectRatio="none" fill="none">
    <polygon points="0,0 1440,0 1440,48 0,72" fill="var(--ink)"/>
  </svg>
</div>

<!-- Gap body — teal wash background -->
<article id="gap" class="section-world gap-world" aria-label="The Daily Gap" style="background: var(--teal-wash); margin-top: -1px;">
<div class="wrap">

  <!-- COVERAGE GAP NOTE — hero highlight card on teal wash -->
  {editorial?.coverage_gap_note && (
  <div style="padding: 32px 0 0;">
    <div class="r">
      <div style="padding: 28px 32px; background: var(--white); border-radius: var(--radius-md); border-left: 4px solid var(--teal); box-shadow: 0 4px 24px rgba(27,42,74,0.06);">
        <span style="font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 14px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--teal-accessible); display: block; margin-bottom: 12px;">What national coverage missed</span>
        <p style="font-family: 'Lora', serif; font-size: clamp(17px, 1.9vw, 22px); line-height: 1.75; color: var(--ink); margin: 0;" set:html={escapeHtml(editorial.coverage_gap_note)} />
      </div>
    </div>
  </div>
  )}

  <!-- SYNTHESIS -->
  {gapStory.synthesis && (
  <div style="padding: 28px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(16px, 1.7vw, 19px); line-height: 1.8; margin-bottom: 0;" set:html={escapeHtml(gapStory.synthesis)} />
    </div>
  </div>
  )}

  <!-- FRAMING INSIGHTS — framing exhibit for Gap -->
  {gapStory.insights && gapStory.insights.length > 0 && (
  <div style="padding: 32px 0 0;">
    <span class="section-label r section-label-teal" style="font-size: 13px; margin-bottom: 20px; display: block;">How outlets framed it</span>
    <div class="r" style="display: flex; flex-direction: column; gap: 0;">
      {gapStory.insights.slice(0, 4).map((insight: string, i: number) => {
        const tierMatch = insight.match(/^(National|International|Local|Specialist|Military|Conservative|Progressive|Analysis)/i);
        const tierName = tierMatch ? tierMatch[1] : '';
        const content = tierMatch ? insight.replace(tierMatch[0], '').replace(/^[-\s]*(?:focused|oriented|leaning)?\s*(?:outlets?|sources?|media|press|coverage)?\s*/i, '').replace(/^[,.:]\s*/, '') : insight;
        return (
        <div class="framing-row" data-tier={tierName || undefined} style={!tierName ? 'background: rgba(59,206,172,0.06);' : ''}>
          {tierName && <div class="framing-label">{tierName}</div>}
          <div class="framing-content" style={`${!tierName ? 'border-left-color: var(--teal);' : ''}`}>
            <span set:html={escapeHtml(content.trim())} />
          </div>
        </div>
        );
      })}
    </div>
  </div>
  )}

  <!-- WHY THIS MATTERS — warm editorial wash -->
  {gapStory.whyThisMatters && (
  <div class="editorial-wash r" style="overflow: hidden;">
    <p class="body" style="font-style: italic; font-size: clamp(17px, 1.9vw, 21px); line-height: 1.7;" set:html={escapeHtml(gapStory.whyThisMatters)} />
  </div>
  )}

  <!-- SOURCES -->
  {gapStory.sourcesSample.length > 0 && (
  <div style="padding: 24px 0 48px;">
    <div class="coverage-label r">Sources reporting</div>
    <div class="coverage-grid r">
      {gapStory.sourcesSample.slice(0, 8).map(sourceName => {
        const geo = getSourceGeo(sourceName);
        return (
        <div class="coverage-card" data-tier={geo?.tier || ''} data-geo={geo?.geo || ''}>
          <div class="coverage-name">{sourceName}{geo && geo.country !== 'US' && <span class="coverage-country">{geo.country}</span>}</div>
          {getSourceContext(sourceName) && (
            <div class="coverage-type">{getSourceContext(sourceName)}</div>
          )}
        </div>
        );
      })}
    </div>
  </div>
  )}
</div>
</article>
)}

<!-- Angled divider: teal wash gap → meanwhile teal wash (subtle wave boundary) -->
<div class="section-divider" aria-hidden="true" style="background: var(--teal-wash);">
  <svg viewBox="0 0 1440 72" preserveAspectRatio="none" fill="none">
    <rect x="0" y="0" width="1440" height="72" fill="var(--teal-wash)"/>
    <path d="M0,0 L0,48 Q360,72 720,36 Q1080,0 1440,48 L1440,0 Z" fill="var(--teal-wash)" opacity="0.5"/>
    <line x1="0" y1="36" x2="1440" y2="36" stroke="var(--green)" stroke-width="1.5" opacity="0.2"/>
  </svg>
</div>

<!-- ================================================================ -->
<!-- MEANWHILE — TEAL WASH BACKGROUND                                 -->
<!-- ================================================================ -->
{meanwhileStory && (
<article id="meanwhile" class="section-world meanwhile-world" aria-label="Meanwhile">
<div class="wrap">
  <div style="padding: 48px 0 0;">
    <span class="section-label section-label-green r">
      <svg class="cat-icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="4" fill="currentColor"/><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/></svg>
      Meanwhile
    </span>
    <h2 class="headline headline-meanwhile r d1">{meanwhileStory.title}</h2>

    <!-- Big number + inline cooperation type sentence -->
    <div class="r d2" style="margin-top: 24px;">
      <div style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
        <div class="display" style="font-size: clamp(40px, 6vw, 64px); line-height: 1; color: var(--green);">{cooperation?.total_cooperation_stories || meanwhileStory.articleCount}</div>
        <div class="stat-annotation stat-annotation-green">
          stories of cooperation, {cooperation?.cooperation_rate || 25}% of everything we read
        </div>
      </div>
      {cooperation && cooperation.by_type && cooperation.by_type.length > 0 && (
        <p style="font-family: 'Lora', serif; font-size: clamp(14px, 1.3vw, 16px); color: var(--ink-light); margin-top: 10px; line-height: 1.6;">
          {cooperation.by_type.map((t: any, i: number) => (
            <span>
              <strong style="color: var(--green-accessible); font-weight: 700;">{t.count}</strong>{' '}{t.type}{i < cooperation.by_type.length - 1 ? ', ' : ''}
            </span>
          ))}
        </p>
      )}
    </div>
  </div>

  <!-- SYNTHESIS — hero content, larger type -->
  {meanwhileStory.synthesis && (
  <div style="padding: 32px 0 0;">
    <div class="r">
      <p class="body r d2" style="font-size: clamp(19px, 2.2vw, 24px); line-height: 1.75; margin-bottom: 0; color: var(--ink);" set:html={escapeHtml(meanwhileStory.synthesis)} />
    </div>
  </div>
  )}

  <!-- WHY THIS MATTERS -->
  {meanwhileStory.whyThisMatters && (
  <div style="padding: 24px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(16px, 1.7vw, 19px); line-height: 1.8; color: var(--ink-mid);" set:html={escapeHtml(meanwhileStory.whyThisMatters)} />
    </div>
  </div>
  )}

  <!-- WATCH FOR -->
  {meanwhileStory.watchFor && (
  <div style="padding: 24px 0 0;">
    <div class="r callout-wash callout-wash-yellow">
      <div class="watch-for-card" style="border-left: 4px solid var(--yellow); padding: 14px 18px; background: rgba(255, 210, 63, 0.13); border-radius: 0 8px 8px 0;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--yellow-accessible); font-weight: 600; display: block; margin-bottom: 8px;">What to watch for</span>
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--ink); margin: 0;" set:html={escapeHtml(meanwhileStory.watchFor)} />
      </div>
    </div>
  </div>
  )}

  <!-- SOURCE FOOTNOTES — minimal, just outlet names -->
  {cooperation && cooperation.highlights && cooperation.highlights.length > 0 && (
  <div style="padding: 24px 0 0;">
    <div class="r" style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--ink-light); line-height: 1.8;">
      Sources: {cooperation.highlights.slice(0, 6).map((h: any, i: number) => (
        <span>
          <a href={h.url || '#'} target="_blank" rel="noopener" style="color: var(--green-accessible); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px;">{h.source}</a>{i < Math.min(cooperation.highlights.length, 6) - 1 ? ', ' : ''}
        </span>
      ))}
    </div>
  </div>
  )}

  <div style="padding-bottom: 48px;"></div>
</div>
</article>
)}

</main>

<!-- ================================================================ -->
<!-- FOOTER — CREAM                                                   -->
<!-- ================================================================ -->
<footer role="contentinfo">
<div class="wrap">
  <div class="section">
    <span class="section-label r">Today's Sources</span>

    <div class="r d1" style="position: relative; display: inline-block; margin-top: 4px;">
      <svg style="position: absolute; top: -18px; left: -24px; width: calc(100% + 48px); height: calc(100% + 36px);" viewBox="0 0 200 120" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <ellipse cx="100" cy="60" rx="90" ry="52" stroke="var(--ink)" stroke-width="2.5" fill="none" opacity="0.3" transform="rotate(-2, 100, 60)" stroke-dasharray="5,4"/>
      </svg>
      <div class="display" style="font-size: clamp(80px, 16vw, 180px); line-height: 1; color: var(--ink);">{totalStories}</div>
    </div>
    <p class="stat-annotation r d2" style="font-size: 22px; margin-top: 4px;">articles analyzed today</p>

    <div class="r d3" style="margin-top: 20px; max-width: 500px;">
      <div style="height: 8px; background: var(--ink-faint); border-radius: 4px; overflow: hidden;" role="progressbar" aria-valuenow={crossDomainPct} aria-valuemin="0" aria-valuemax="100" aria-label={`${crossDomainPct}% of stories crossed domain boundaries`}>
        <div style={`height: 100%; width: ${crossDomainPct}%; background: var(--ink); border-radius: 4px;`}></div>
      </div>
      <div style="display: flex; justify-content: space-between; margin-top: 6px;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light);">{crossDomain} cross-domain</span>
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light);">{totalStories} total</span>
      </div>
    </div>

    <div class="pills r d4">
      {domains.slice(0, 12).map((domain: string) => (
        <span class="pill">{domain}</span>
      ))}
    </div>

    <!-- Editorial sign-off -->
    <p class="r" style="margin-top: 32px; font-family: 'Lora', Georgia, serif; font-size: clamp(15px, 1.5vw, 18px); color: var(--ink-mid); max-width: 600px; line-height: 1.7;">
      Signal Board reads {totalMonitoredSources} sources every day across the political spectrum, across borders, and across languages, because the outlets being squeezed out by consolidation and platform economics are the ones doing the most essential reporting.
    </p>

    <!-- Substack CTA — oversized Abril Fatface -->
    <div class="r" style="margin-top: 40px;">
      <a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" class="cta-oversized">
        Get tomorrow's<br>analysis <span class="cta-arrow">&rarr;</span>
      </a>
      <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--ink-light); margin-top: 12px;">Free on Substack. No algorithms, just the picture.</p>
    </div>

    <nav aria-label="Footer navigation" style="margin-top: 40px; font-family: 'Inter', sans-serif; font-size: 13px; color: var(--ink-light);">
      <a href="/signal-board/about/" style="color: var(--ink-light);">About</a>&ensp;·&ensp;<a href="/signal-board/archive/" style="color: var(--ink-light);">Archive</a>&ensp;·&ensp;<a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" style="color: var(--ink-light);">Subscribe</a>&ensp;·&ensp;<a href="https://github.com/ehasseltine/signal-board" target="_blank" rel="noopener" style="color: var(--ink-light);">Source</a>
    </nav>

    <div style="margin-top: 20px; padding-bottom: 32px; font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light); opacity: 0.7;">
      Signal Board · Created by <a href="https://www.elisehasseltine.com" style="color: var(--ink-light);">Elise Hasseltine</a> · Last updated: <time datetime={dateStr}>{dateStr}</time> · No tracking · No ads
    </div>
  </div>
</div>
</footer>

</BaseLayout>
