    'Economics': { dot: '#0EAD69', bg: 'rgba(215,255,26,0.18)' },
    'Information': { dot: '#1789FC', bg: 'rgba(215,255,26,0.18)' },
    'Climate': { dot: '#42F0A5', bg: 'rgba(215,255,26,0.18)' },
    'Labor': { dot: '#F87575', bg: 'rgba(215,255,26,0.18)' },
    'AI': { dot: '#1B2A4B', bg: 'rgba(215,255,26,0.18)' },
  };
  return colors[domain] || { dot: '#1B2A4B', bg: 'rgba(215,255,26,0.14)' };
}

