  function addDays(dateStr, n) {
    var d = new Date(dateStr + 'T12:00:00Z');
    d.setUTCDate(d.getUTCDate() + n);
    return d.toISOString().split('T')[0];
  }
  var dates = [];
  for (var i = 0; i < 7; i++) {
    dates.push(addDays(todayDate, -i));
  }

  // 3. Fetch ALL available daily files for corpus count + the 6 older days
  var olderFetches = dates.slice(1).map(function(date) {
    return fetch('/data/daily/' + date + '.json')
      .then(function(r) { return r.ok ? r.json() : null; })
      .catch(function() { return null; });
  });
  var olderResults = await Promise.all(olderFetches);

  // 4. Build dayData map with proper key mapping
  var allResults = [todayData].concat(olderResults);
  var dayData = {};
  var validDates = [];

  allResults.forEach(function(data, i) {
    if (!data) return;
    var date = dates[i];
    validDates.push(date);
    var dom = (data.summary || {}).domain_distribution || {};
    var domKeys = Object.keys(dom);

    // Detect if this JSON has the new 15-key format
    var hasNewFormat = domKeys.some(function(k) { return k === 'War & Conflict' || k === "Who's in Charge" || k === 'Oil & Energy'; });

    if (hasNewFormat) {
      // New format: map display names to internal keys
      var labelCounts = {};
      LABEL_KEYS.forEach(function(k) { labelCounts[k] = 0; });
      Object.keys(dom).forEach(function(rawKey) {
        var internal = KEY_MAP[rawKey] || rawKey;
        if (labelCounts.hasOwnProperty(internal)) {
          labelCounts[internal] += dom[rawKey];
        }
      });
      dayData[date] = {
        total: (data.summary || {}).total_stories || 0,
        labels: labelCounts,
        topStories: data.top_stories || [],
        eventDivergence: data.event_divergence || [],
      };
    } else if (RECLASSIFIED_FALLBACK[date]) {
      // Old format: use reclassified data
      var fb = RECLASSIFIED_FALLBACK[date];
      var labelCounts = {};
      LABEL_KEYS.forEach(function(k) { labelCounts[k] = fb[k] || 0; });
      dayData[date] = {
        total: fb.total,
        labels: labelCounts,
        topStories: data.top_stories || [],
        eventDivergence: data.event_divergence || [],
      };
    } else {
      // Old format, no fallback: map what we can
      var labelCounts = {};
      LABEL_KEYS.forEach(function(k) { labelCounts[k] = 0; });
      Object.keys(dom).forEach(function(rawKey) {
        var internal = KEY_MAP[rawKey] || rawKey;
        if (labelCounts.hasOwnProperty(internal)) {
          labelCounts[internal] += dom[rawKey];
        }
      });
      dayData[date] = {
        total: (data.summary || {}).total_stories || 0,
        labels: labelCounts,
        topStories: data.top_stories || [],
        eventDivergence: data.event_divergence || [],
      };
    }
  });

  // 5. Compute corpus totals across all available days
  initCorpusStrip(validDates, dayData, todayData);

  // 6. Init data-dependent sections
  initSeismograph(validDates, dayData);
  initDivergence(todayData);
})();


/* ═════════════════════════════════════════
   CORPUS STRIP — surface the dataset scale
═════════════════════════════════════════ */
function initCorpusStrip(validDates, dayData, todayData) {
  var totalEl = document.getElementById('cs-total');
  var daysEl = document.getElementById('cs-days');
  var activeEl = document.getElementById('cs-active');

  // Sum all articles across all loaded days
  var corpusTotal = 0;
  validDates.forEach(function(d) {
    if (dayData[d]) corpusTotal += dayData[d].total;
  });

  // Fetch extra days we aren't displaying to get accurate corpus count
  // Attempt to load all known days from the data directory
  var extraDates = ['2026-03-28','2026-03-29','2026-03-30','2026-03-31','2026-03-15'];
  var extraFetches = extraDates.filter(function(d) { return !dayData[d]; }).map(function(date) {
    return fetch('/data/daily/' + date + '.json')
      .then(function(r) { return r.ok ? r.json() : null; })
      .catch(function() { return null; });
  });

  Promise.all(extraFetches).then(function(results) {
    var extraTotal = 0;
    var extraDays = 0;
    results.forEach(function(data) {
      if (data && data.summary) {
        extraTotal += data.summary.total_stories || 0;
        extraDays++;
      }
    });

    var grandTotal = corpusTotal + extraTotal;
    var totalDays = validDates.length + extraDays;

    totalEl.textContent = grandTotal.toLocaleString();
    daysEl.textContent = totalDays;
    activeEl.textContent = (todayData.summary || {}).sources_reporting || '—';

    // Animate the total count
    var target = grandTotal;
    var dur = 1400;
    var start = performance.now();
    function tick(now) {
      var t = Math.min(1, (now - start) / dur);
      var ease = easeOutQuart(t);
      totalEl.textContent = Math.round(ease * target).toLocaleString();
      if (t < 1) rAF(tick);
    }
    rAF(tick);
  });
}


/* ═════════════════════════════════════════
   1. GAME OF LIFE — hero canvas
═════════════════════════════════════════ */
function initGoL() {
  var canvas = document.getElementById('gol-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var SZ = 13;
  var COLS = ['#FF2D55','#FF9500','#30D158','#0A84FF','#BF5AF2','#FFD60A'];
  var W, H, cols, rows, grid, next, colors;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cols = Math.ceil(W/SZ)+1; rows = Math.ceil(H/SZ)+1;
    grid = new Uint8Array(cols*rows); next = new Uint8Array(cols*rows);
    colors = new Uint8Array(cols*rows);
    for (var i=0;i<grid.length;i++) { grid[i]=Math.random()<0.2?1:0; colors[i]=Math.floor(Math.random()*6); }
  }

  function step() {
    for (var r=0;r<rows;r++) for (var c=0;c<cols;c++) {
      var n=0, idx=r*cols+c;
      for (var dr=-1;dr<=1;dr++) for (var dc=-1;dc<=1;dc++) {
        if(!dr&&!dc) continue;
        n+=grid[((r+dr+rows)%rows)*cols+((c+dc+cols)%cols)];
      }
      if (grid[idx]) next[idx]=(n===2||n===3)?1:0;
      else { next[idx]=n===3?1:0; if(n===3) colors[idx]=Math.floor(Math.random()*6); }
    }
    var tmp=grid; grid=next; next=tmp;
  }

  var fr=0;
  function draw() {
    ctx.clearRect(0,0,W,H);
    for (var r=0;r<rows;r++) for (var c=0;c<cols;c++) {
      if (!grid[r*cols+c]) continue;
      ctx.globalAlpha=0.48; ctx.fillStyle=COLS[colors[r*cols+c]];
      ctx.beginPath(); ctx.roundRect(c*SZ+1,r*SZ+1,SZ-2,SZ-2,2); ctx.fill();
    }
    ctx.globalAlpha=1;
    var g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0,'rgba(8,8,14,0.35)'); g.addColorStop(0.45,'rgba(8,8,14,0.55)'); g.addColorStop(1,'rgba(8,8,14,0.96)');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
    fr++; if(fr%4===0) step();
    rAF(draw);
  }
  resize(); draw();
  window.addEventListener('resize', resize);
}


/* ═════════════════════════════════════════
   COUNT-UPS — hero stats
═════════════════════════════════════════ */
function initCountUps() {
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if(!e.isIntersecting) return; io.unobserve(e.target);
      var target=parseInt(e.target.dataset.target), dur=1400, start=performance.now();
      function tick(now) {
        var t=Math.min(1,(now-start)/dur), ease=easeOutQuart(t);
        e.target.textContent=Math.round(ease*target).toLocaleString();
        if(t<1) rAF(tick);
      }
      rAF(tick);
    });
  }, {threshold:0.5});
  document.querySelectorAll('.hs-n[data-target]').forEach(function(el){io.observe(el)});
}


/* ═════════════════════════════════════════
   2. THE SEISMOGRAPH — 7 cols × 15 rows
   Height = normalized article volume.
   Color = label color, varying by day.
   Selected cell → detail panel with real stories.
═════════════════════════════════════════ */
function initSeismograph(dates, dayData) {
  var datesRow  = document.getElementById('sg-dates');
  var labelsCol = document.getElementById('sg-labels');
  var gridEl    = document.getElementById('sg-grid');
  var detailEl  = document.getElementById('sg-detail-inner');
  var annotEl   = document.getElementById('sg-annotations');
  if (!datesRow || !labelsCol || !gridEl) return;

  // Per-label max (for per-label normalization — gives each row full height range)
  var labelMax = {};
  LABEL_KEYS.forEach(function(key) {
    var vals = dates.map(function(d) {
      return dayData[d] ? (dayData[d].labels[key] || 0) : 0;
    });
    labelMax[key] = Math.max.apply(null, vals);
  });

  var selected = null;

  // ── Build date headers ──────────────────
  dates.forEach(function(date, i) {
    var el = document.createElement('div');
    el.className = 'sg-date-label' + (i===0 ? ' today' : '');
    var d = new Date(date + 'T12:00:00Z');
    el.textContent = d.toLocaleDateString('en-US', { month:'short', day:'numeric' });
    datesRow.appendChild(el);
  });

  // ── Build label column ──────────────────
  LABEL_KEYS.forEach(function(key) {
    var el = document.createElement('div');
    el.className = 'sg-label-row';
    el.textContent = LABELS[key].name;
    el.dataset.key = key;
    el.style.color = LABELS[key].color + '99';
    labelsCol.appendChild(el);
  });

  // ── Build grid: one column per date ──────
  var cells = {};

  dates.forEach(function(date, di) {
    var col = document.createElement('div');
    col.style.cssText = 'flex:1; display:flex; flex-direction:column; gap:4px;';
    cells[date] = {};

    LABEL_KEYS.forEach(function(key) {
      var val = dayData[date] ? (dayData[date].labels[key] || 0) : 0;
      var pct = labelMax[key] > 0 ? (val / labelMax[key] * 100) : 0;
      var color = LABELS[key].color;

      var cell = document.createElement('div');
      cell.style.cssText = 'height:24px; flex:none; position:relative; background:#18182A; border-radius:2px; cursor:pointer; overflow:hidden; transition:transform 0.12s;';
      cell.dataset.date = date;
      cell.dataset.key = key;
      cell.dataset.val = val;
      cell.addEventListener('mouseover', function(){cell.style.transform='scale(1.06)';cell.style.zIndex='10';});
      cell.addEventListener('mouseout', function(){cell.style.transform='';cell.style.zIndex='';});

      var fill = document.createElement('div');
      fill.style.cssText = 'position:absolute; bottom:0; left:0; right:0; border-radius:2px; opacity:0.85; height:0%; transition:height 1.2s cubic-bezier(0.16,1,0.3,1);';
      fill.style.background = 'linear-gradient(0deg, ' + color + 'DD, ' + color + '66)';

      var num = document.createElement('div');
      num.style.cssText = 'position:absolute; bottom:2px; left:0; right:0; text-align:center; font-family:Space Mono,monospace; font-size:8px; font-weight:700; pointer-events:none; z-index:5; opacity:0; transition:opacity 0.15s;';
      num.style.color = color;
      num.textContent = val;
      cell.addEventListener('mouseover', function(){num.style.opacity='1';});
      cell.addEventListener('mouseout', function(){num.style.opacity='0';});

      cell.appendChild(fill);
      cell.appendChild(num);
      col.appendChild(cell);
      cells[date][key] = { cell: cell, fill: fill, pct: pct, val: val };

      cell.addEventListener('click', (function(dt, ky, cl) {
        return function() { selectCell(dt, ky, cl); };
      })(date, key, color));
    });

    gridEl.appendChild(col);
  });

  // ── Animate bars in on scroll ────────────
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      io.unobserve(e.target);
      dates.forEach(function(date, di) {
        LABEL_KEYS.forEach(function(key, li) {
          var c = cells[date][key];
          setTimeout(function() {
            c.fill.style.height = Math.max(c.pct, 4) + '%';
          }, di * 35 + li * 8);
        });
      });
    });
  }, { threshold: 0.1 });
  io.observe(gridEl);

  // Label and grid rows are both fixed 24px + 4px gap — no sync needed.

  // ── Build spike annotations ────────────
  // Find the biggest moves: which labels spiked the most on which days
  if (annotEl) {
    var annotations = [];
    dates.forEach(function(date) {
      var ctx = STORY_CONTEXT[date] || {};
      Object.keys(ctx).forEach(function(key) {
        if (ctx[key].story && dayData[date] && dayData[date].labels[key] > 50) {
          var d = new Date(date + 'T12:00:00Z');
          var dateLabel = d.toLocaleDateString('en-US', { month:'short', day:'numeric' });
          annotations.push({
            date: dateLabel,
            color: LABELS[key] ? LABELS[key].color : '#fff',
            label: LABELS[key] ? LABELS[key].name : key,
            story: ctx[key].story,
            count: dayData[date].labels[key],
          });
        }
      });
    });
    // Show the top annotations (highest article counts, max 6)
    annotations.sort(function(a,b) { return b.count - a.count; });
    annotations.slice(0, 6).forEach(function(ann) {
      var el = document.createElement('div');
      el.className = 'sg-annotation';
      el.innerHTML = '<span class="ann-label" style="color:' + ann.color + '">' + ann.label + '</span> ' +
        ann.date + ' · ' + ann.count + ' articles — ' + ann.story;
      annotEl.appendChild(el);
    });
  }

  // ── Cell selection + detail panel ────────
  function selectCell(date, key, color) {
    if (selected) {
      var prev = cells[selected.date] && cells[selected.date][selected.key];
      if (prev) prev.cell.style.boxShadow = '';
      var prevLabel = labelsCol.querySelector('[data-key="' + selected.key + '"]');
      if (prevLabel) prevLabel.classList.remove('active');
    }

    selected = { date: date, key: key };
    cells[date][key].cell.style.boxShadow = '0 0 0 2px #FFD60A';
    var labelEl = labelsCol.querySelector('[data-key="' + key + '"]');
    if (labelEl) labelEl.classList.add('active');

    renderDetail(date, key, color);
  }

  function renderDetail(date, key, color) {
    var val = dayData[date] ? (dayData[date].labels[key] || 0) : 0;
    var label = LABELS[key].name;
    var d = new Date(date + 'T12:00:00Z');
    var dateStr = d.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

    // Get story context and sample articles
    var ctx = (STORY_CONTEXT[date] || {})[key] || {};
    var storyLine = ctx.story || '';
    var samples = ctx.articles || [];

    var storyHTML = storyLine ? '<div class="sdi-story">' + storyLine + '</div>' : '';

    var articleHTML = '';
    if (samples.length) {
      articleHTML = samples.map(function(a) {
        return '<div class="sdi-article">' +
          '<div class="sdi-src" style="color:' + color + '">' + a.source + '</div>' +
          '<div class="sdi-title">' + a.title + '</div>' +
          '</div>';
      }).join('');
    } else {
      articleHTML = '<div class="sdi-article"><div class="sdi-title" style="color:var(--dim)">' +
        val + ' articles tagged "' + label + '" on ' + dateStr + '.' +
        '</div></div>';
    }

    detailEl.innerHTML =
      '<div class="sdi-header">' +
        '<span class="sdi-label" style="color:' + color + '">' + label + '</span>' +
        '<span class="sdi-date"> \u00B7 ' + dateStr + '</span>' +
        '<span class="sdi-count" style="color:' + color + '"> \u00B7 ' + val + ' articles</span>' +
      '</div>' +
      storyHTML +
      '<div class="sdi-articles">' + articleHTML + '</div>';

    detailEl.closest('.sg-detail').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Auto-select today's highest cell on load
  setTimeout(function() {
    var todayDate = dates[0];
    var maxKey = 'war_and_conflict', maxVal = 0;
    LABEL_KEYS.forEach(function(key) {
      var v = dayData[todayDate] ? (dayData[todayDate].labels[key] || 0) : 0;
      if (v > maxVal) { maxVal = v; maxKey = key; }
    });
    selectCell(todayDate, maxKey, LABELS[maxKey].color);
  }, 1800);
}


/* ═════════════════════════════════════════
   3. DIVERGENCE — fetched from pipeline
   Source dots start at center, drift to
   their frame position on a spectrum.
   Names the actual story with evidence.
═════════════════════════════════════════ */
function initDivergence(todayData) {
  var canvas = document.getElementById('diverge-canvas');
  var tip = document.getElementById('div-tooltip');
  if (!canvas || !tip) return;
  var ctx = canvas.getContext('2d');

  var scoreEl = document.getElementById('div-score-big');
  var titleEl = document.getElementById('div-title');
  var subEl = document.getElementById('div-sub');
  var evidenceEl = document.getElementById('div-evidence');

  var topCluster = (todayData.event_divergence || [])[0];
  if (!topCluster) {
    titleEl.textContent = 'No divergence cluster found today';
    return;
  }

  var score = topCluster.divergence ? topCluster.divergence.score : (topCluster.score || 0);
  var articles = topCluster.articles || [];
  var allSources = topCluster.sources || [];
  var sourceCount = allSources.length || articles.length;
  var entities = topCluster.shared_entities || topCluster.entities || [];
  var rawForce = topCluster.structural_force || topCluster.label || '';
  var articleCount = topCluster.divergence ? topCluster.divergence.article_count : (topCluster.all_article_count || articles.length);
  var kwDiv = topCluster.divergence ? topCluster.divergence.keyword_divergence : 0;

  // Display name mapping
  var FORCE_DISPLAY = {
    'war_and_conflict':'War & Conflict','whos_in_charge':"Who's in Charge",
    'rules_and_courts':'Rules & Courts','money_and_prices':'Money & Prices',
    'oil_and_energy':'Oil & Energy','global_relations':'Global Relations',
    'rights_and_justice':'Rights & Justice','ai_and_technology':'AI & Technology',
    'communities':'Communities','health':'Health','work_and_workers':'Work & Workers',
    'media_and_information':'Media & Information','the_environment':'The Environment',
    'food_and_land':'Food & Land','people_power':'People Power',
  };
  var forceDisplay = FORCE_DISPLAY[rawForce] || rawForce;

  // Build the actual story name from entities and headlines
  var storyName = '';
  if (entities.length > 0) {
    var entityStr = entities.map(function(e) { return e.charAt(0).toUpperCase() + e.slice(1); }).join(', ');
    storyName = entityStr;
  }
  // Derive story description from article headlines
  var storyDesc = '';
  if (articles.length > 0) {
    // Find the most common theme from headlines
    var firstTitle = articles[0].title || '';
    if (firstTitle.toLowerCase().indexOf('iran') > -1) {
      storyName = 'The Iran War';
      storyDesc = 'US airstrikes, Trump\u2019s ceasefire deadline, Strait of Hormuz closure';
    } else {
      storyDesc = firstTitle.split(' - ')[0].split(' | ')[0];
    }
  }

  // Update header text with specific story
  titleEl.textContent = sourceCount + ' sources. ' + articleCount + ' articles. One story.';
  var line1 = storyName ? storyName + ' \u2014 ' : '';
  line1 += forceDisplay + ' framing divergence: ' + score.toFixed(2);
  if (kwDiv) line1 += ' \u00B7 Keyword divergence: ' + kwDiv.toFixed(2);
  var line2 = storyDesc ? storyDesc : 'Measured by how differently each outlet framed the same event.';
  subEl.innerHTML = '<span>' + line1 + '</span><br><span style="color:var(--yellow);opacity:0.7">' + line2 + '</span>';

  // Build evidence cards from articles
  if (evidenceEl && articles.length > 0) {
    // Show sample articles as proof — left-leaning vs right-leaning frames
    var leftArticles = articles.slice(0, Math.min(3, articles.length));
    var rightArticles = articles.slice(Math.max(0, articles.length - 3));
    var shown = [];
    leftArticles.concat(rightArticles).forEach(function(a) {
      if (shown.indexOf(a.source) > -1) return;
      shown.push(a.source);
      var card = document.createElement('div');
      card.className = 'div-ev-card';
      card.innerHTML = '<div class="div-ev-src" style="color:#FFD60A">' + a.source + '</div>' +
        '<div class="div-ev-title">' + (a.title || '') + '</div>';
      evidenceEl.appendChild(card);
    });
  }

  // Build ALL nodes from sources[] (37), using articles[] only for tier/title lookup
  var articleLookup = {};
  articles.forEach(function(a) {
    if (a.source) articleLookup[a.source] = { tier: a.tier || 'international', title: a.title || '' };
  });

  var TIER_ORDER = ['national','newsletter','analysis','government','international','specialist','local-regional'];
  var PALETTE = ['#FF2D55','#FF6B00','#FFD60A','#FF9500','#30D158','#00D4FF','#0A84FF','#BF5AF2','#5AC8FA','#34C759'];

  var rawNodes = allSources.map(function(srcName) {
    var info = articleLookup[srcName] || { tier: 'international', title: '' };
    return { source: srcName, tier: info.tier, title: info.title };
  }).sort(function(a, b) {
    return TIER_ORDER.indexOf(a.tier) - TIER_ORDER.indexOf(b.tier);
  });

  var nodes = rawNodes.map(function(n, i) {
    var tierBase = {'national':0,'newsletter':1,'analysis':2,'government':3,'international':4,'specialist':7,'local-regional':5};
    var base = tierBase[n.tier] || 4;
    return {
      source: n.source,
      color: PALETTE[(base + Math.floor(i / 4)) % PALETTE.length],
      title: n.title,
      angle: rawNodes.length > 1 ? i / (rawNodes.length - 1) : 0.5,
      phase: seededRand(i * 11 + 5) * Math.PI * 2,
    };
  });

  if (!nodes.length) return;

  // Animate score number
  var targetScore = score;
  var io0 = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return; io0.unobserve(e.target);
      var dur=1600, start=performance.now();
      function tick(now) {
        var t=Math.min(1,(now-start)/dur), ease=easeOut(t);
        scoreEl.textContent = (ease * targetScore).toFixed(2);
        if(t<1) rAF(tick);
      }
      rAF(tick);
    });
  }, {threshold:0.5});
  io0.observe(scoreEl);

  var W, H, builtNodes=[], progress=0, started=false;

  function buildNodes() {
    W = canvas.offsetWidth; H = 480; canvas.height = H;
    canvas.width = W;
    var cy = H * 0.48;
    var INSET_L = 80;   /* room for left labels */
    var INSET_R = 120;  /* room for right labels */
    var INSET_Y = 48;   /* top/bottom padding */
    builtNodes = nodes.map(function(a, i) {
      return {
        source: a.source,
        color: a.color,
        title: a.title,
        angle: a.angle,
        tx: INSET_L + a.angle * (W - INSET_L - INSET_R) + (seededRand(i*7+1) - 0.5) * 32,
        ty: INSET_Y + (seededRand(i*13+3)) * (H - INSET_Y * 2),
        x: W/2, y: cy,
        phase: a.phase,
        labelY: 0,  /* will be set by collision pass */
      };
    });
    /* ── Label collision avoidance ──────────── */
    /* Sort by x to process left-to-right, then nudge overlapping labels */
    var sorted = builtNodes.slice().sort(function(a,b) { return a.tx - b.tx; });
    var LABEL_H = 14;  /* approx label height */
    var LABEL_W = 80;  /* approx label width */
    for (var i = 0; i < sorted.length; i++) {
      var n = sorted[i];
      n.labelY = n.ty + 18; /* default: below dot */
      /* Check against all previously placed labels */
      for (var j = 0; j < i; j++) {
        var other = sorted[j];
        var dx = Math.abs(n.tx - other.tx);
        var dy = Math.abs(n.labelY - other.labelY);
        if (dx < LABEL_W && dy < LABEL_H) {
          /* Collision detected — try above the dot */
          n.labelY = n.ty - 22;
          /* Check again above */
          for (var k = 0; k < i; k++) {
            var o2 = sorted[k];
            if (Math.abs(n.tx - o2.tx) < LABEL_W && Math.abs(n.labelY - o2.labelY) < LABEL_H) {
              /* Still colliding — offset further */
              n.labelY = n.ty - 36;
              break;
            }
          }
          break;
        }
      }
    }
  }

  var t=0;
  function draw() {
    ctx.clearRect(0,0,W,H);
    t += 0.012;
    if (!started) { rAF(draw); return; }
    progress = Math.min(1, progress + 0.014);
    var ease = easeOut(progress);
    var totalDots = builtNodes.length;

    builtNodes.forEach(function(n, i) {
      var startAt = (i / totalDots) * 0.45;
      var dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      var dotEase = easeOut(dotP);
      n.x = lerp(W/2, n.tx, dotEase);
      n.y = lerp(H/2, n.ty, dotEase);
    });

    // Connection line
    if (builtNodes.length >= 2) {
      var xs = builtNodes.map(function(n){return n.x});
      var x0=Math.min.apply(null,xs)-20, x1=Math.max.apply(null,xs)+20;
      ctx.globalAlpha = ease * 0.15;
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 1; ctx.setLineDash([4,6]);
      ctx.beginPath(); ctx.moveTo(x0,H*0.42); ctx.lineTo(x1,H*0.42); ctx.stroke();
      ctx.setLineDash([]);
    }

    // Source dots
    builtNodes.forEach(function(n, i) {
      var startAt = (i / totalDots) * 0.45;
      var dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      if (dotP === 0) return;
      var pulse = 0.78 + 0.22 * Math.sin(t*1.3 + n.phase);
      var grd = ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,26);
      grd.addColorStop(0, n.color+'AA'); grd.addColorStop(1, n.color+'00');
      ctx.globalAlpha = 0.5*dotP*pulse; ctx.fillStyle = grd;
      ctx.beginPath(); ctx.arc(n.x,n.y,26,0,Math.PI*2); ctx.fill();
      ctx.globalAlpha = dotP*pulse; ctx.fillStyle = n.color;
      ctx.beginPath(); ctx.arc(n.x,n.y,11,0,Math.PI*2); ctx.fill();
      if (dotP > 0.7) {
        var a = (dotP-0.7)/0.3;
        /* Use pre-computed labelY with collision avoidance */
        var ly = lerp(H/2 + 18, n.labelY, dotEase);
        var above = (n.labelY < n.ty);  /* label above dot? */
        ctx.globalAlpha = a*0.85; ctx.fillStyle = n.color;
        ctx.font = "bold 10px 'Space Grotesk'"; ctx.textAlign='center';
        ctx.textBaseline = above ? 'bottom' : 'top';
        ctx.fillText(n.source, n.x, ly);
      }
    });

    // Spectrum labels — specific to the actual story
    if (ease > 0.7) {
      var a = (ease-0.7)/0.3;
      var midY = H * 0.48;
      ctx.globalAlpha = a*0.25; ctx.fillStyle='#F0F0F5';
      ctx.font="bold 9px 'Space Mono'"; ctx.textAlign='left'; ctx.textBaseline='middle';
      ctx.fillText('\u2190 US MILITARY FRAME', 16, H - 24);
      ctx.textAlign='right';
      ctx.fillText('IRAN SOVEREIGNTY FRAME \u2192', W-16, H - 24);
      ctx.globalAlpha = a*0.05; ctx.strokeStyle='#ffffff';
      ctx.lineWidth=1; ctx.setLineDash([4,6]);
      ctx.beginPath(); ctx.moveTo(80, H - 24); ctx.lineTo(W-120, H - 24); ctx.stroke();
      ctx.setLineDash([]);
    }
    ctx.globalAlpha=1; ctx.textAlign='left'; ctx.textBaseline='alphabetic';
    rAF(draw);
  }

  // Replay animation on scroll into view
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        buildNodes();
        progress = 0;
        builtNodes.forEach(function(n) { n.x = W/2; n.y = H/2; });
        started = true;
        rAF(draw);
      }
    });
  }, { threshold: 0.2 });
  io.observe(canvas.closest('.diverge-sec'));
  window.addEventListener('resize', function() { if (started) { buildNodes(); progress=0; } });

  canvas.addEventListener('mousemove', function(e) {
    var rect=canvas.getBoundingClientRect();
    var mx=(e.clientX-rect.left)*(W/rect.width);
    var my=(e.clientY-rect.top)*(H/rect.height);
    var hit=builtNodes.find(function(n){return Math.hypot(mx-n.x,my-n.y)<18});
    if (hit) {
      tip.style.display='block';
      tip.style.left=(e.clientX+14)+'px'; tip.style.top=(e.clientY-8)+'px';
      tip.innerHTML='<div class="tt-name" style="color:'+hit.color+'">'+hit.source+'</div>' +
        (hit.title ? '<div class="tt-text">'+hit.title+'</div>' : '');
    } else tip.style.display='none';
  });
  canvas.addEventListener('mouseleave',function(){tip.style.display='none'});
}


/* ─── NAV scroll state ──────────────────── */
function initNav() {
  var nav=document.querySelector('.nav');
  window.addEventListener('scroll',function(){nav.classList.toggle('solid',window.scrollY>80)},{passive:true});
}
</script>

</body>
</html>
