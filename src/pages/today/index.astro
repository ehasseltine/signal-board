---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadLatestData } from '../../lib/data';
import {
  selectDailyThread,
  selectDailyGap,
  selectMeanwhile
} from '../../lib/storySelection';
import type { MegaStory, Editorial, Cooperation, StorySynthesis } from '../../lib/storySelection';

// Load the pipeline data
const pipelineData = loadLatestData();

// Extract ALL data fields — supports both legacy and current pipeline formats
const megaStories: MegaStory[] = pipelineData.mega_stories || [];
const whatConnects = pipelineData.what_connects || [];
const topStories = pipelineData.top_stories || [];
const narrativeDivergence = pipelineData.narrative_divergence || [];
const cooperation: Cooperation | null = pipelineData.cooperation || null;
const editorial: Editorial | undefined = pipelineData.editorial || undefined;
const localRegionalSynthesis: string = pipelineData.local_regional_synthesis || '';
const localRegionalExamples: any[] = pipelineData.local_regional_examples || [];
const storySyntheses: StorySynthesis[] = pipelineData.story_syntheses || [];

// Select stories using whichever data is available
const threadStory = selectDailyThread(megaStories, whatConnects, topStories, editorial, storySyntheses);
const gapStory = selectDailyGap(megaStories, narrativeDivergence, topStories, editorial, threadStory?.title, storySyntheses);
const meanwhileStory = selectMeanwhile(
  megaStories,
  cooperation,
  localRegionalSynthesis,
  localRegionalExamples,
  editorial,
  threadStory?.title || '',
  gapStory?.title || '',
  storySyntheses
);

const dateStr = pipelineData.date || new Date().toISOString().split('T')[0];
const summary = pipelineData.summary || {};

// Summary stats
const domainDistribution = summary.domain_distribution || {};
const domains = Object.keys(domainDistribution);
const totalStories = summary.total_stories || 0;
const sourcesReporting = summary.sources_reporting || 0;
const crossDomainPct = summary.cross_domain_pct || 0;
const crossDomain = summary.cross_domain || 0;

// Total sources Signal Board monitors (not just today's active sources)
const totalMonitoredSources = 275;

// Helpers
function escapeHtml(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function getSourceContext(sourceName: string): string | null {
  const SOURCE_CONTEXT: Record<string, string> = {
    'Dawn': 'Founded 1941, oldest English-language newspaper in Pakistan',
    'Arab American News': 'Published in Dearborn MI since 1984, independent',
    'The Advocate': 'Oldest LGBTQ+ publication in US, founded 1967',
    'Colorado Sun': 'Founded 2018 by ex-Denver Post journalists',
    'Indian Country Today': 'Native American news, founded 1981',
    'El Diario NY': 'Oldest Spanish-language daily in US',
    'Inside Climate News': 'Pulitzer-winning nonprofit climate journalism',
    'Mother Jones': 'Nonprofit investigative journalism',
    'The Marshall Project': 'Nonprofit criminal justice journalism',
    'Rappler': 'Philippine digital news, Maria Ressa, Nobel laureate',
    'South China Morning Post': 'Hong Kong-based English-language daily since 1903',
    'Times of India': 'World\'s largest English-language daily newspaper',
    'Straits Times': 'Singapore\'s newspaper of record since 1845',
    'BBC World': 'British Broadcasting Corporation, global news service',
    'NHK World': 'Japan\'s public broadcaster, international service',
    'The Hindu': 'India\'s national newspaper since 1878',
    'ABC Australia': 'Australia\'s national public broadcaster',
    'The Globe and Mail': 'Canada\'s newspaper of record',
    'Military Times': 'Independent news for the military community',
    'The Root': 'Black news, opinion, politics, and culture',
    'Atlanta Black Star': 'Independent Black media outlet',
    'The Grio': 'Digital platform for African American stories',
    'Hechinger Report': 'Nonprofit education journalism',
    'AsAmNews': 'Asian American news and features',
    'MinnPost': 'Nonprofit news for Minnesota',
    'Texas Tribune': 'Nonprofit Texas news',
    'Heritage Foundation': 'Conservative think tank, founded 1973',
    'Breitbart': 'Right-leaning news and opinion',
    'Daily Wire': 'Conservative media company',
    'Fox News': 'Right-leaning cable news network',
    'Washington Times': 'Conservative daily newspaper',
    'RealClearPolitics': 'Political news aggregation and analysis',
    'NBC News': 'American broadcast news',
    'ABC News': 'American broadcast news network',
    'New York Times': 'American newspaper of record',
    'The Atlantic': 'American magazine of culture and politics',
    'NPR': 'National Public Radio',
    'Reuters': 'International wire service',
    'Bloomberg': 'Financial and business news',
    'CNBC': 'Business and financial news network',
    'Lawfare': 'National security law analysis',
    'Naked Capitalism': 'Finance and economics blog',
    'National Catholic Reporter': 'Independent Catholic news',
    'Religion News Service': 'Interfaith religion journalism',
  };
  return SOURCE_CONTEXT[sourceName] || null;
}

function tierLabel(tier: string): string {
  const labels: Record<string, string> = {
    'national': 'National',
    'international': 'International',
    'local-regional': 'Local & Regional',
    'specialist': 'Specialist',
    'analysis': 'Analysis',
    'explainer': 'Explainer',
    'newsletter': 'Newsletter',
    'research': 'Research',
  };
  return labels[tier] || tier;
}

// Dot grid for article count visualization
function dotCount(articles: number): number {
  return Math.min(Math.ceil(articles / 20), 30);
}
---

<BaseLayout title="Today">

<!-- MASTHEAD — NAVY -->
<div class="masthead-wrap">
  <div class="wrap">
    <div class="masthead">
      <div class="r">
        <div class="display masthead-title">SIGNAL</div>
        <div class="display masthead-title">BOARD</div>
      </div>
      <span class="masthead-date r d1">{dateStr}</span>
      <h1 class="masthead-hook r d2">
        {editorial?.headline || `Today, ${totalMonitoredSources} sources published ${totalStories} stories. When you see them together, a picture emerges.`}
      </h1>
      <p class="masthead-sub r d3">
        {editorial?.subheadline || `${crossDomain} stories crossed domain boundaries — ${crossDomainPct}% of everything we read. That's where the connections live.`}
      </p>
      <div class="scroll-cue">
        <span>scroll</span>
        <svg width="18" height="10" viewBox="0 0 18 10" fill="none">
          <path d="M2,2 L9,8 L16,2" stroke="var(--cream)" stroke-width="1.5" stroke-linecap="round" opacity="0.35"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<!-- SUMMARY CARDS — CREAM -->
<div class="wrap-wide" style="padding-top: clamp(48px, 7vw, 80px); padding-bottom: clamp(24px, 4vw, 40px);">
  <div class="summary-grid r">

    {threadStory && (
    <a href="#thread" class="summary-card" style="text-decoration: none; color: inherit;">
      <div class="card-label">
        <svg width="18" height="14" viewBox="0 0 22 18" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <line x1="1" y1="4" x2="21" y2="4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="4" y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/>
          <line x1="7" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.25"/>
        </svg>The Daily Thread
      </div>
      <div class="card-stat card-stat-ink">{threadStory.articleCount}</div>
      <div class="card-meta">articles from {threadStory.sourceCount} sources</div>
      <div class="card-hook">{threadStory.title}</div>
      <span class="card-arrow">Read &darr;</span>
    </a>
    )}

    {gapStory && (
    <a href="#gap" class="summary-card" style="text-decoration: none; color: inherit;">
      <div class="card-label">
        <svg width="16" height="14" viewBox="0 0 20 18" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <rect x="1" y="1" width="6" height="16" rx="1" fill="currentColor"/>
          <rect x="13" y="1" width="6" height="16" rx="1" fill="currentColor" opacity="0.25"/>
        </svg>The Daily Gap
      </div>
      <div class="card-stat">{gapStory.sourceCount} <span style="font-family: 'Lora', serif; font-size: clamp(14px, 1.5vw, 17px); font-style: italic; color: var(--ink-mid);">sources</span></div>
      <div class="card-meta">covering what others miss</div>
      <div class="card-hook">{gapStory.title}</div>
      <span class="card-arrow">Read &darr;</span>
    </a>
    )}

    <a href="#meanwhile" class="summary-card summary-card-green" style="text-decoration: none; color: inherit;">
      <div class="card-label card-label-green">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="vertical-align: -2px; margin-right: 6px;">
          <circle cx="10" cy="10" r="4" fill="currentColor"/>
          <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        </svg>Meanwhile
      </div>
      <div class="card-stat card-stat-green">{cooperation?.total_cooperation_stories || '—'}</div>
      <div class="card-meta">{cooperation ? `stories of people showing up (${cooperation.cooperation_rate}%)` : 'who showed up today'}</div>
      <div class="card-hook">Local and specialist outlets cover what the national cycle misses.</div>
      <span class="card-arrow">Read &darr;</span>
    </a>

  </div>
</div>

<!-- ================================================================ -->
<!-- THE DAILY THREAD — CREAM BACKGROUND                              -->
<!-- ================================================================ -->
{threadStory && (
<div id="thread">
<div class="wrap">
  <div class="section" style="padding-bottom: 0;">
    <span class="section-label r">
      <svg class="cat-icon" width="22" height="18" viewBox="0 0 22 18" fill="none"><line x1="1" y1="4" x2="21" y2="4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="4" y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/><line x1="7" y1="14" x2="15" y2="14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.25"/></svg>
      The Daily Thread
    </span>
    <h2 class="headline r d1">{threadStory.title}</h2>

    {threadStory.changeDescription && (
      <p class="r d1" style="font-family: 'Caveat', cursive; font-size: clamp(18px, 2vw, 22px); color: var(--red); margin-top: 8px;">
        {threadStory.changeDescription}
      </p>
    )}
  </div>
</div>

<!-- ARTICLE COUNT VISUALIZATION -->
<div class="wrap-wide">
  <div style="margin: 32px auto 0; padding: 0 clamp(16px, 3vw, 32px);" class="r">
    <div style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
      <div class="display" style="font-size: clamp(48px, 8vw, 80px); line-height: 1; color: var(--red);">{threadStory.articleCount}</div>
      <div style="font-family: 'Lora', serif; font-size: clamp(16px, 1.5vw, 19px); color: var(--ink-mid);">
        articles from <strong>{threadStory.sourceCount} sources</strong>
      </div>
    </div>

    <!-- Dot grid -->
    <div style="display: flex; flex-wrap: wrap; gap: 6px; margin: 16px 0; max-width: 400px;">
      {Array.from({ length: dotCount(threadStory.articleCount) }).map(() => (
        <div style="width: 14px; height: 14px; border-radius: 50%; background: var(--red);"></div>
      ))}
      {Array.from({ length: Math.max(0, 30 - dotCount(threadStory.articleCount)) }).map(() => (
        <div style="width: 14px; height: 14px; border-radius: 50%; background: var(--red); opacity: 0.15;"></div>
      ))}
    </div>

    <!-- Source tier breakdown -->
    {Object.keys(threadStory.sourceTiers).length > 0 && (
    <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px;">
      {Object.entries(threadStory.sourceTiers).map(([tier, count]) => (
        <span style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--ink-light); background: var(--ink-faint); padding: 4px 10px; border-radius: 20px;">
          {tierLabel(tier)}: {count}
        </span>
      ))}
    </div>
    )}
  </div>
</div>

<!-- SYNTHESIS — The actual analysis -->
<div class="wrap">
  <div style="padding: 40px 0 0;">
    {threadStory.synthesis && (
      <div class="r">
        <p class="body r d2" style="font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8;" set:html={escapeHtml(threadStory.synthesis)} />
      </div>
    )}
  </div>
</div>

<!-- CROSS-SPECTRUM — How different outlets cover it -->
{threadStory.crossSpectrum && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <div class="r">
      <span class="section-label" style="font-size: 13px; margin-bottom: 12px; display: block;">Across the spectrum</span>
      <div style="border-left: 4px solid var(--red); padding: 20px 24px; background: rgba(27, 42, 74, 0.04); border-radius: 0 8px 8px 0;">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--ink);" set:html={escapeHtml(threadStory.crossSpectrum)} />
      </div>
    </div>
  </div>
</div>
)}

<!-- WHY THIS MATTERS — Personal relevance -->
{threadStory.whyThisMatters && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <div class="r">
      <span class="section-label" style="font-size: 13px; margin-bottom: 12px; display: block; color: var(--red);">Why this matters to you</span>
      <p class="body" style="font-size: clamp(16px, 1.7vw, 19px); line-height: 1.8; font-style: italic;" set:html={escapeHtml(threadStory.whyThisMatters)} />
    </div>
  </div>
</div>
)}

<!-- WATCH FOR -->
{threadStory.watchFor && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <div class="r">
      <span class="section-label" style="font-size: 13px; margin-bottom: 12px; display: block; color: var(--green);">What to watch for</span>
      <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8;" set:html={escapeHtml(threadStory.watchFor)} />
    </div>
  </div>
</div>
)}

<!-- SOURCES -->
{threadStory.sourcesSample.length > 0 && (
<div class="wrap">
  <div style="padding: 32px 0 clamp(72px, 10vw, 120px);">
    <div class="coverage-label r">Sources reporting</div>
    <div class="coverage-grid r">
      {threadStory.sourcesSample.slice(0, 8).map(sourceName => (
        <div class="coverage-card">
          <div class="coverage-name">{sourceName}</div>
          {getSourceContext(sourceName) && (
            <div class="coverage-type">{getSourceContext(sourceName)}</div>
          )}
        </div>
      ))}
    </div>
  </div>
</div>
)}
</div>
)}

<!-- ================================================================ -->
<!-- THE DAILY GAP — NAVY BACKGROUND                                  -->
<!-- ================================================================ -->
{gapStory && (
<div id="gap" class="navy">
<div class="wrap">
  <div class="section" style="padding-bottom: 0;">
    <span class="section-label r">
      <svg class="cat-icon" width="20" height="18" viewBox="0 0 20 18" fill="none"><rect x="1" y="1" width="6" height="16" rx="1" fill="currentColor"/><rect x="13" y="1" width="6" height="16" rx="1" fill="currentColor" opacity="0.25"/></svg>
      The Daily Gap
    </span>
    <h2 class="headline r d1">{gapStory.title}</h2>

    {gapStory.changeDescription && (
      <p class="r d1" style="font-family: 'Caveat', cursive; font-size: clamp(18px, 2vw, 22px); color: var(--red); margin-top: 8px;">
        {gapStory.changeDescription}
      </p>
    )}

    <!-- Article + source count -->
    <div class="r d2" style="margin-top: 24px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
      <div class="display" style="font-size: clamp(40px, 6vw, 64px); line-height: 1; color: var(--red);">{gapStory.articleCount}</div>
      <div style="font-family: 'Lora', serif; font-size: clamp(15px, 1.4vw, 18px); color: var(--on-navy-dim);">
        articles from <strong style="color: var(--cream);">{gapStory.sourceCount} sources</strong>
      </div>
    </div>
  </div>
</div>

<!-- SYNTHESIS -->
{gapStory.synthesis && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8; color: var(--on-navy-dim);" set:html={escapeHtml(gapStory.synthesis)} />
    </div>
  </div>
</div>
)}

<!-- FRAMING INSIGHTS — How different outlets tell the same story -->
{gapStory.insights && gapStory.insights.length > 0 && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <span class="section-label r" style="font-size: 13px; margin-bottom: 16px; display: block; color: var(--red);">How outlets framed it</span>
    {gapStory.insights.slice(0, 4).map((insight: string) => (
      <div class="r" style="margin-bottom: 16px; padding: 16px 20px; background: rgba(255, 255, 255, 0.06); border-radius: 0 8px 8px 0; border-left: 4px solid var(--red);">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.7; color: var(--on-navy-dim);" set:html={escapeHtml(insight)} />
      </div>
    ))}
  </div>
</div>
)}

<!-- WHY THIS MATTERS -->
{gapStory.whyThisMatters && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(16px, 1.7vw, 19px); line-height: 1.8; font-style: italic; color: var(--cream);" set:html={escapeHtml(gapStory.whyThisMatters)} />
    </div>
  </div>
</div>
)}

<!-- SOURCES -->
{gapStory.sourcesSample.length > 0 && (
<div class="wrap">
  <div style="padding: 32px 0 clamp(72px, 10vw, 120px);">
    <div class="coverage-label r" style="color: var(--on-navy-dim);">Sources reporting</div>
    <div class="coverage-grid r">
      {gapStory.sourcesSample.slice(0, 8).map(sourceName => (
        <div class="coverage-card" style="background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.1);">
          <div class="coverage-name" style="color: var(--cream);">{sourceName}</div>
          {getSourceContext(sourceName) && (
            <div class="coverage-type" style="color: var(--on-navy-dim);">{getSourceContext(sourceName)}</div>
          )}
        </div>
      ))}
    </div>
  </div>
</div>
)}
</div>
)}

<!-- ================================================================ -->
<!-- MEANWHILE — GREEN WASH BACKGROUND                                -->
<!-- ================================================================ -->
{meanwhileStory && (
<div id="meanwhile" style="background: #EFF5EE;">
<div class="wrap">
  <div class="section" style="padding-bottom: 0;">
    <span class="section-label section-label-green r">
      <svg class="cat-icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="4" fill="currentColor"/><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/></svg>
      Meanwhile
    </span>
    <h2 class="headline r d1">{meanwhileStory.title}</h2>
  </div>
</div>

<!-- SYNTHESIS -->
{meanwhileStory.synthesis && (
<div class="wrap">
  <div style="padding: 24px 0 0;">
    <div class="r">
      <p class="body r d2" style="font-size: clamp(17px, 1.8vw, 20px); line-height: 1.8;" set:html={escapeHtml(meanwhileStory.synthesis)} />
    </div>
  </div>
</div>
)}

<!-- LOCAL EXAMPLES / INSIGHTS -->
{meanwhileStory.insights && meanwhileStory.insights.length > 0 && (
<div class="wrap">
  <div style="padding: 32px 0 0;">
    {meanwhileStory.insights.slice(0, 3).map((insight: string) => (
      <div class="r" style="margin-bottom: 24px; padding: 20px 24px; background: rgba(45, 138, 78, 0.06); border-radius: 8px; border-left: 4px solid var(--green);">
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8;" set:html={escapeHtml(insight)} />
      </div>
    ))}
  </div>
</div>
)}

<!-- WHY THIS MATTERS -->
{meanwhileStory.whyThisMatters && (
<div class="wrap">
  <div style="padding: 24px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; font-style: italic; color: var(--ink-mid);" set:html={escapeHtml(meanwhileStory.whyThisMatters)} />
    </div>
  </div>
</div>
)}

<div class="wrap">
  <div style="padding: 32px 0 clamp(72px, 10vw, 120px);">
  </div>
</div>
</div>
)}

<!-- ================================================================ -->
<!-- CLOSE — NAVY                                                     -->
<!-- ================================================================ -->
<div class="close-section">
  <div class="wrap">
    <h2 class="headline r" style="color: var(--cream); margin-bottom: 24px;">
      {editorial?.headline || `Today, ${sourcesReporting} sources published ${totalStories} stories. Here's what stood out.`}
    </h2>

    {editorial?.coverage_gap_note && (
      <div class="r d1" style="margin-bottom: 24px;">
        <span class="section-label" style="color: var(--red); font-size: 13px; margin-bottom: 8px; display: block;">What national coverage missed</span>
        <p class="body" style="color: var(--on-navy-dim);" set:html={escapeHtml(editorial.coverage_gap_note)} />
      </div>
    )}

    {editorial?.thread_to_watch && (
      <div class="r d2" style="margin-bottom: 24px;">
        <span class="section-label" style="color: var(--green); font-size: 13px; margin-bottom: 8px; display: block;">Thread to watch</span>
        <p class="body" style="color: var(--on-navy-dim);" set:html={escapeHtml(editorial.thread_to_watch)} />
      </div>
    )}

    <p class="body r d3" style="color: var(--on-navy-dim); margin-top: 32px;">
      Signal Board reads {totalMonitoredSources} sources every day across the political spectrum, across borders, and across languages, because the outlets being squeezed out by consolidation and platform economics are the ones doing the most essential reporting.
    </p>
  </div>
</div>

<!-- ================================================================ -->
<!-- SOURCES — CREAM                                                  -->
<!-- ================================================================ -->
<div class="wrap">
  <div class="section">
    <span class="section-label r">Today's Sources</span>

    <div class="r d1" style="position: relative; display: inline-block; margin-top: 4px;">
      <svg style="position: absolute; top: -14px; left: -20px; width: calc(100% + 40px); height: calc(100% + 28px);" viewBox="0 0 200 120" fill="none" preserveAspectRatio="none">
        <ellipse cx="100" cy="60" rx="90" ry="52" stroke="var(--red)" stroke-width="2" fill="none" opacity="0.25" transform="rotate(-2, 100, 60)" stroke-dasharray="5,4"/>
      </svg>
      <div class="display" style="font-size: clamp(64px, 13vw, 150px); line-height: 1;">{totalStories}</div>
    </div>
    <p class="r d2" style="font-family: 'Caveat', cursive; font-size: 22px; color: var(--ink-light); margin-top: 4px;">articles analyzed today</p>

    <div class="r d3" style="margin-top: 20px; max-width: 500px;">
      <div style="height: 8px; background: var(--ink-faint); border-radius: 4px; overflow: hidden;">
        <div style={`height: 100%; width: ${crossDomainPct}%; background: var(--red); border-radius: 4px;`}></div>
      </div>
      <div style="display: flex; justify-content: space-between; margin-top: 6px;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light);">{crossDomain} cross-domain</span>
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: var(--ink-light);">{totalStories} total</span>
      </div>
    </div>

    <div class="pills r d4">
      {domains.slice(0, 12).map((domain: string) => (
        <span class="pill">{domain}</span>
      ))}
    </div>

