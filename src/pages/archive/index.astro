---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listDailyDates, loadDailyData } from '../../lib/data';

const dates = listDailyDates();

const formatDate = (d: string) => {
  const [y, m, day] = d.split('-');
  const dt = new Date(+y, +m - 1, +day);
  return dt.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
};

// Load data for each date to populate rich archive cards
interface ArchiveEntry {
  date: string;
  formattedDate: string;
  editorialHeadline: string;
  threadForce: string;
  gapForce: string;
  cooperationCount: number;
  totalStories: number;
  sourcesReporting: number;
}

const entries: ArchiveEntry[] = dates.map(date => {
  const data = loadDailyData(date);
  if (!data) return null;

  const editorial = data.editorial || {};
  const cooperation = data.cooperation || {};
  const summary = data.summary || {};
  const storySyntheses = data.story_syntheses || [];

  // Get Thread and Gap structural forces from story_syntheses
  const threadSynth = storySyntheses.find((s: any) => s.role === 'thread');
  const gapSynth = storySyntheses.find((s: any) => s.role === 'gap');

  // Format structural force: "regulatory capture" → "Regulatory Capture"
  const titleCase = (s: string) => s ? s.replace(/\b\w/g, c => c.toUpperCase()) : '';

  return {
    date,
    formattedDate: formatDate(date),
    editorialHeadline: editorial.accessible_headline || editorial.headline || '',
    threadForce: titleCase(threadSynth?.structural_force || ''),
    gapForce: titleCase(gapSynth?.structural_force || ''),
    cooperationCount: cooperation.total_cooperation_stories || 0,
    totalStories: summary.total_stories || 0,
    sourcesReporting: summary.sources_reporting || 0,
  };
}).filter(Boolean) as ArchiveEntry[];
---

<BaseLayout title="Archive | Signal Board">

<main id="main-content">

<nav aria-label="Breadcrumb" style="padding: 16px clamp(24px, 4vw, 48px) 0;">
  <div class="wrap">
    <ol style="list-style: none; padding: 0; margin: 0; font-family: 'Inter', sans-serif; font-size: 13px; color: var(--ink-light); display: flex; gap: 8px; align-items: center;">
      <li><a href="/today/" style="color: var(--ink-light);">Signal Board</a></li>
      <li aria-hidden="true" style="color: var(--ink-faint);">/</li>
      <li aria-current="page">Archive</li>
    </ol>
  </div>
</nav>

<div class="masthead-wrap" style="min-height: auto; padding: clamp(48px, 8vw, 80px) 0;">
  <div class="wrap">
    <div class="masthead" style="padding: 0;">
      <div class="r">
        <h1 class="display masthead-title">Archive</h1>
      </div>
      <p class="masthead-sub r d1" style="color: var(--cream); margin-top: clamp(24px, 4vw, 40px);">
        Every edition of Signal Board, from the day the pipeline went live. Each one reads
        the same sources, asks the same seven questions, and lets the structural picture
        speak for itself.
      </p>
    </div>
  </div>
</div>

<section class="wrap" style="padding: clamp(48px, 8vw, 80px) clamp(24px, 4vw, 48px);" aria-label="Daily editions">
  <div class="section" style="padding: 0; max-width: 720px; margin: 0 auto;">

    {entries.map(entry => (
      <a href={`/archive/${entry.date}/`} class="archive-card-link" style="text-decoration: none; color: inherit; display: block; margin-bottom: clamp(20px, 3vw, 32px);">
        <article class="archive-card r">

          {/* Date */}
          <time datetime={entry.date} class="archive-card-date">
            {entry.formattedDate}
          </time>

          {/* Editorial headline */}
          {entry.editorialHeadline && (
            <h2 class="archive-card-headline">
              {entry.editorialHeadline}
            </h2>
          )}

          {/* Section metadata row */}
          <div class="archive-card-sections">
            {entry.threadForce && (
              <span class="archive-section-tag archive-section-thread">
                Thread: {entry.threadForce}
              </span>
            )}
            {entry.gapForce && (
              <span class="archive-section-tag archive-section-gap">
                Gap: {entry.gapForce}
              </span>
            )}
            {entry.cooperationCount > 0 && (
              <span class="archive-section-tag archive-section-meanwhile">
                Meanwhile: {entry.cooperationCount} stories
              </span>
            )}
          </div>

          {/* Stats row */}
          <div class="archive-card-stats">
            <span>{entry.totalStories} stories</span>
            <span class="archive-stat-sep" aria-hidden="true">·</span>
            <span>{entry.sourcesReporting} sources</span>
          </div>

          <span class="archive-card-read">Read this edition &rarr;</span>

        </article>
      </a>
    ))}

    {entries.length === 0 && (
      <div style="text-align: center; padding: clamp(48px, 10vw, 100px) 0;">
        <p class="body" style="color: var(--ink-light);">No archives available yet. Check back soon.</p>
      </div>
    )}

  </div>
</section>

</main>

<footer role="contentinfo">
<div class="wrap">
  <nav aria-label="Footer navigation" style="padding: 40px 0; font-family: 'Inter', sans-serif; font-size: 13px; color: var(--ink-light); border-top: 1px solid var(--ink-faint);">
    <a href="/today/" style="color: var(--ink-light);">Today's Analysis</a>&ensp;·&ensp;<a href="/about/" style="color: var(--ink-light);">About</a>&ensp;·&ensp;<a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" style="color: var(--ink-light);">Subscribe</a>
  </nav>
</div>
</footer>

</BaseLayout>

<style>
  .archive-card {
    padding: clamp(24px, 3vw, 36px);
    background: rgba(255, 208, 123, 0.12);
    border: 1px solid var(--ink-faint);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    position: relative;
    transition: transform var(--duration-hover) var(--ease-spring),
                box-shadow var(--duration-hover) var(--ease-spring),
                border-color var(--duration-hover) var(--ease-out-expo);
  }
  .archive-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--tangerine);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }
  .archive-card-link:hover .archive-card {
    border-color: var(--tangerine);
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .archive-card-date {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tangerine-text);
    display: block;
    margin-bottom: 12px;
  }

  .archive-card-headline {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 600;
    line-height: 1.4;
    color: var(--ink-body);
    margin: 0 0 16px 0;
  }

  .archive-card-sections {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .archive-section-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 4px 10px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .archive-section-thread {
    background: rgba(204, 51, 51, 0.08);
    color: var(--tangerine-text);
  }
  .archive-section-gap {
    background: rgba(66, 240, 165, 0.12);
    color: var(--violet-text);
  }
  .archive-section-meanwhile {
    background: rgba(45, 138, 78, 0.08);
    color: var(--cyan-text);
  }

  .archive-card-stats {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: var(--ink-mid);
    margin-bottom: 4px;
  }
  .archive-stat-sep {
    margin: 0 6px;
    color: var(--ink-faint);
  }

  .archive-card-read {
    position: absolute;
    bottom: 16px;
    right: 20px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: var(--ink-light);
    opacity: 0;
    transition: opacity var(--duration-hover) var(--ease-out);
  }
  .archive-card-link:hover .archive-card-read {
    opacity: 1;
  }

  @media (max-width: 600px) {
    .archive-card-sections {
      flex-direction: column;
      gap: 6px;
    }
    .archive-section-tag {
      display: inline-block;
      width: fit-content;
    }
  }
</style>
