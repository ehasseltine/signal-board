---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadLatestData } from '../../lib/data';
import {
  selectDailyThread,
  selectDailyGap,
  selectMeanwhile
} from '../../lib/storySelection';
import type { MegaStory, Editorial, Cooperation, StorySynthesis } from '../../lib/storySelection';

// Load the pipeline data
const pipelineData = loadLatestData();

// Extract ALL data fields — supports both legacy and current pipeline formats
const megaStories: MegaStory[] = pipelineData.mega_stories || [];
const whatConnects = pipelineData.what_connects || [];
const topStories = pipelineData.top_stories || [];
const narrativeDivergence = pipelineData.narrative_divergence || [];
const cooperation: Cooperation | null = pipelineData.cooperation || null;
const editorial: Editorial | undefined = pipelineData.editorial || undefined;
const localRegionalSynthesis: string = pipelineData.local_regional_synthesis || '';
const localRegionalExamples: any[] = pipelineData.local_regional_examples || [];
const storySyntheses: StorySynthesis[] = pipelineData.story_syntheses || [];

// Select stories using whichever data is available
const threadStory = selectDailyThread(megaStories, whatConnects, topStories, editorial, storySyntheses);
const gapStory = selectDailyGap(megaStories, narrativeDivergence, topStories, editorial, threadStory?.title, storySyntheses);
const meanwhileStory = selectMeanwhile(
  megaStories,
  cooperation,
  localRegionalSynthesis,
  localRegionalExamples,
  editorial,
  threadStory?.title || '',
  gapStory?.title || '',
  storySyntheses
);

const dateStr = pipelineData.date || new Date().toISOString().split('T')[0];
const summary = pipelineData.summary || {};

// Summary stats
const domainDistribution = summary.domain_distribution || {};
const domains = Object.keys(domainDistribution);
const totalStories = summary.total_stories || 0;
const sourcesReporting = summary.sources_reporting || 0;
const crossDomainPct = summary.cross_domain_pct || 0;
const crossDomain = summary.cross_domain || 0;

// Total sources Signal Board monitors (not just today's active sources)
const totalMonitoredSources = 300;

// Helpers
function escapeHtml(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// Check if the editorial coverage_gap_note matches the Gap section's structural force.
// The coverage_gap_note is a global editorial field that may describe a gap in a completely
// different story. Only show it in the Gap section if it references outlets or topics from the Gap.
const gapForceLabel = storySyntheses.find(s => s.role === 'gap')?.structural_force || '';
const gapSources = (narrativeDivergence.find(nd =>
  nd.structural_force?.toLowerCase() === gapForceLabel.toLowerCase()
)?.articles || []).map(a => a.source);
const coverageGapMatchesGap = (() => {
  const note = editorial?.coverage_gap_note?.toLowerCase() || '';
  if (!note) return false;
  // Check if the note mentions any of the Gap section's sources
  if (gapSources.some(s => note.includes(s.toLowerCase()))) return true;
  // Check if the note mentions keywords from the Gap's structural force
  const forceWords = gapForceLabel.toLowerCase().split(/\s+/).filter(w => w.length > 3);
  if (forceWords.some(w => note.includes(w))) return true;
  return false;
})();

// Build per-section outlet → article URL maps.
// Each section gets URLs from its own story's articles only.
// This prevents an outlet appearing in multiple stories from getting the wrong URL.
function buildUrlMap(articles: Array<{ source?: string; url?: string }>): Map<string, string> {
  const map = new Map<string, string>();
  for (const a of articles) {
    if (a.source && a.url && !map.has(a.source)) {
      map.set(a.source, a.url);
    }
  }
  return map;
}

// Find the top_stories entry matching each section's structural force
const threadSynthForce = storySyntheses.find(s => s.role === 'thread')?.structural_force?.toLowerCase() || '';
const gapSynthForce = storySyntheses.find(s => s.role === 'gap')?.structural_force?.toLowerCase() || '';

const threadTopStory = topStories.find(ts => ts.structural_force?.toLowerCase() === threadSynthForce) || topStories[0];
const gapTopStory = topStories.find(ts => ts.structural_force?.toLowerCase() === gapSynthForce) || topStories[1];

// Also check narrative_divergence for the gap (it may have different/better article URLs)
const gapND = narrativeDivergence.find(nd => nd.structural_force?.toLowerCase() === gapSynthForce);

const threadUrlMap = buildUrlMap(threadTopStory?.articles || []);
const gapUrlMap = buildUrlMap([
  ...(gapND?.articles || []),
  ...(gapTopStory?.articles || []),
]);

// Meanwhile uses cooperation highlights + all_source_urls (complete cooperation article URL index)
const meanwhileUrlMap = new Map<string, string>();
if (cooperation) {
  // Primary: all_source_urls covers every cooperation-tagged outlet (added in analyze.py)
  const allUrls = (cooperation as any).all_source_urls || {};
  for (const [src, url] of Object.entries(allUrls)) {
    if (src && url && !meanwhileUrlMap.has(src)) {
      meanwhileUrlMap.set(src, url as string);
    }
  }
  // Fallback: highlights (for older data that may lack all_source_urls)
  for (const h of (cooperation.highlights || [])) {
    if (h.source && h.url && !meanwhileUrlMap.has(h.source)) {
      meanwhileUrlMap.set(h.source, h.url);
    }
  }
}

// Global fallback map (for any outlet not in a section-specific map)
const outletUrlMap = new Map<string, string>();
for (const story of topStories) {
  for (const article of (story.articles || [])) {
    if (article.source && article.url && !outletUrlMap.has(article.source)) {
      outletUrlMap.set(article.source, article.url);
    }
  }
}
for (const nd of narrativeDivergence) {
  for (const article of (nd.articles || [])) {
    if (article.source && article.url && !outletUrlMap.has(article.source)) {
      outletUrlMap.set(article.source, article.url);
    }
  }
}
if (cooperation) {
  for (const h of (cooperation.highlights || [])) {
    if (h.source && h.url && !outletUrlMap.has(h.source)) {
      outletUrlMap.set(h.source, h.url);
    }
  }
}
// article_url_index: fallback for any outlet the synthesis mentions
// that isn't in the section-specific or top_stories article arrays
const articleUrlIndex: Record<string, string> = (pipelineData as any).article_url_index || {};
for (const [src, url] of Object.entries(articleUrlIndex)) {
  if (src && url && !outletUrlMap.has(src)) {
    outletUrlMap.set(src, url);
  }
}

// Load canonical source metadata (single source of truth for descriptions)
import sourcesRaw from '../../../data/sources.json';
const sourcesData: Record<string, { description?: string; tier?: string; region?: string }> = sourcesRaw as any;

// Build outlet → context description lookup
// Primary: canonical sources.json (always has all 300 outlets)
// Fallback: pipeline JSON article.context fields (for any outlets not in sources.json)
const outletContextMap = new Map<string, string>();

// First: load all descriptions from sources.json
for (const [name, entry] of Object.entries(sourcesData)) {
  if (entry.description) {
    outletContextMap.set(name, entry.description);
  }
}

// Then: overlay any pipeline-specific context (in case pipeline has newer descriptions)
for (const story of topStories) {
  for (const article of (story.articles || [])) {
    if (article.source && article.context && !outletContextMap.has(article.source)) {
      outletContextMap.set(article.source, article.context);
    }
  }
  for (const conn of (story.connections || [])) {
    if (conn.source && conn.context && !outletContextMap.has(conn.source)) {
      outletContextMap.set(conn.source, conn.context);
    }
  }
  if (story.tier_framing) {
    for (const [, data] of Object.entries(story.tier_framing)) {
      const sample = (data as any)?.sample;
      if (sample?.source && sample?.context && !outletContextMap.has(sample.source)) {
        outletContextMap.set(sample.source, sample.context);
      }
    }
  }
}
for (const nd of narrativeDivergence) {
  for (const article of (nd.articles || [])) {
    if (article.source && article.context && !outletContextMap.has(article.source)) {
      outletContextMap.set(article.source, article.context);
    }
  }
}

// Source names that collide with common English phrases and should not be auto-linked
// in editorial text. These are valid sources in the pipeline but their names appear
// naturally in prose (e.g. "Drug pricing emerged from White House meetings").
const LINKIFY_BLOCKLIST = new Set([
  'White House', 'Congress', 'Pentagon', 'State Department',
  'Treasury', 'Senate', 'House',
]);

// Escape text then wrap known outlet names with hyperlinks.
// sectionMap takes priority — it has the correct URL for this section.
// Falls back to the global outletUrlMap for outlets not in the section's own data.
function linkifyText(text: string, sectionMap?: Map<string, string>): string {
  let html = escapeHtml(text);
  // Merge: section-specific URLs override global URLs
  const mergedMap = new Map(outletUrlMap);
  if (sectionMap) {
    for (const [k, v] of sectionMap) {
      mergedMap.set(k, v);
    }
  }
  // Remove blocklisted names that collide with common English
  for (const blocked of LINKIFY_BLOCKLIST) {
    mergedMap.delete(blocked);
  }
  // Sort outlet names longest-first to avoid partial matches
  const outlets = Array.from(mergedMap.keys()).sort((a, b) => b.length - a.length);
  for (const outlet of outlets) {
    const url = mergedMap.get(outlet)!;
    // Match the outlet name as a whole word (not inside another word)
    // Use a simple string replacement — first occurrence only for each outlet per block
    const escaped = escapeHtml(outlet);
    const idx = html.indexOf(escaped);
    if (idx !== -1) {
      // Make sure we're not inside an existing tag
      const before = html.substring(0, idx);
      const after = html.substring(idx + escaped.length);
      if (!before.match(/<[^>]*$/) && !after.match(/^[^<]*>/)) {
        html = before + `<a href="${escapeHtml(url)}" target="_blank" rel="noopener" class="outlet-link">${escaped}</a>` + after;
      }
    }
  }
  return html;
}

function getSourceContext(sourceName: string): string | null {
  // Exact match first
  const exact = outletContextMap.get(sourceName);
  if (exact) return exact;
  // Normalized match: lowercase, strip hyphens and periods
  const normalize = (s: string) => s.toLowerCase().replace(/[-.']/g, '').replace(/\s+/g, ' ').trim();
  const normalized = normalize(sourceName);
  for (const [key, value] of outletContextMap.entries()) {
    if (normalize(key) === normalized) {
      if (!outletContextMap.has(sourceName)) {
        console.log(`[Source lookup] Fuzzy matched "${sourceName}" → "${key}"`);
      }
      return value;
    }
  }
  console.log(`[Source lookup] No match for "${sourceName}"`);
  return null;
}

// Look up outlet URL with fuzzy matching (try exact, then " News"/" World" suffix, then without "The " prefix)
function lookupOutletUrl(label: string, sectionMap?: Map<string, string>): string {
  const maps = sectionMap ? [sectionMap, outletUrlMap] : [outletUrlMap];
  for (const map of maps) {
    const url = map.get(label) || map.get(label + ' News') || map.get(label + ' World') || map.get(label.replace(/^The /, ''));
    if (url) return url;
  }
  return '';
}

// Split cross_spectrum text into sentences, handling abbreviations like U.S., U.K., D.C.
function splitSentences(text: string): string[] {
  // Replace common abbreviations with placeholder (no periods)
  const abbrevs = ['U.S.', 'U.K.', 'U.N.', 'E.U.', 'D.C.', 'U.S.A.'];
  let safe = text;
  for (const abbr of abbrevs) {
    safe = safe.split(abbr).join(abbr.replace(/\./g, '\u200B'));
  }
  // Split on sentence boundaries: period followed by whitespace
  const parts = safe.split(/(?<=\.)\s+/).filter((s: string) => s.trim().length > 10);
  // Restore abbreviations
  return parts.map(s => {
    for (const abbr of abbrevs) {
      s = s.split(abbr.replace(/\./g, '\u200B')).join(abbr);
    }
    return s;
  });
}

// All known outlet names from pipeline + sources.json, sorted longest-first for matching
const allOutletNames = Array.from(new Set([
  ...Array.from(outletUrlMap.keys()),
  ...Array.from(outletContextMap.keys()),
  ...Object.keys(sourcesData),
])).sort((a, b) => b.length - a.length);

// Look up tier for an outlet: first from sources.json, then from pipeline data
function getOutletTier(outletName: string): string {
  // Primary: sources.json canonical tier
  const src = sourcesData[outletName];
  if (src?.tier) return src.tier;
  // Fallback: scan pipeline articles
  for (const story of topStories) {
    for (const a of (story.articles || [])) {
      if (a.source === outletName && a.tier) return a.tier;
    }
  }
  for (const nd of narrativeDivergence) {
    for (const a of (nd.articles || [])) {
      if (a.source === outletName && a.tier) return a.tier;
    }
  }
  return '';
}

// Extract outlet name from the beginning of a framing sentence
// Uses known outlet names for reliable matching instead of verb-pattern guessing
function extractOutletFromSentence(sentence: string): string | null {
  for (const name of allOutletNames) {
    if (sentence.startsWith(name + ' ') || sentence.startsWith(name + "'s ")) {
      return name;
    }
  }
  // Second pass: the synthesis may drop "The" from outlet names like "The Globe and Mail"
  // Try prepending "The " to find a match
  for (const name of allOutletNames) {
    if (name.startsWith('The ')) {
      const shortName = name.slice(4); // "Globe and Mail"
      if (sentence.startsWith(shortName + ' ') || sentence.startsWith(shortName + "'s ")) {
        return name; // Return canonical name with "The"
      }
    }
  }
  return null;
}

function tierLabel(tier: string): string {
  const labels: Record<string, string> = {
    'national': 'National',
    'international': 'International',
    'local-regional': 'Local & Regional',
    'specialist': 'Specialist',
    'analysis': 'Analysis',
    'explainer': 'Explainer',
    'newsletter': 'Newsletter',
    'research': 'Research',
  };
  return labels[tier] || tier;
}

function getDomainColor(domain: string): { dot: string; bg: string } {
  const colors: Record<string, { dot: string; bg: string }> = {
