<div class="section-diagonal section-diagonal--gap-to-meanwhile" aria-hidden="true"></div>

<!-- ================================================================ -->
<!-- MEANWHILE — MINT ROOM                                            -->
<!-- ================================================================ -->
{meanwhileStory && (
<article id="meanwhile" class="section-world meanwhile-world" aria-label="Meanwhile" style="overflow: hidden;">
<div class="wrap" style="position: relative; z-index: 1;">
  <div style="padding: 48px 0 0;">
    <span class="section-label section-label-cyan r">
      <svg class="cat-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="4" fill="currentColor"/><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" opacity="0.3"/></svg>
      Meanwhile
    </span>
    <h2 class="headline headline-meanwhile r d1">{meanwhileStory.title}</h2>

    <!-- Big number + cooperation type cards -->
    <div class="r d2" style="margin-top: 24px;">
      <div style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
        <div class="display" style="font-size: clamp(48px, 8vw, 80px); line-height: 1; color: var(--cyan);">{cooperation?.total_cooperation_stories || meanwhileStory.articleCount}</div>
        <div class="stat-annotation stat-annotation-green" style="font-size: clamp(18px, 2vw, 24px);">
          stories of cooperation, {cooperation?.cooperation_rate || 25}% of everything we read
        </div>
      </div>
      {cooperation && cooperation.by_type && cooperation.by_type.length > 0 && (
        <div class="coop-grid">
          {cooperation.by_type.map((t: any) => (
            <div class="coop-type-card">
              <div class="coop-type-count">{t.count}</div>
              <div class="coop-type-label">{t.type}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- SYNTHESIS — lead sentence callout + collapsible rest -->
  {meanwhileStory.synthesis && (() => {
    const synthSentences = splitSentences(meanwhileStory.synthesis);
    const lead = synthSentences[0] || '';
    const rest = synthSentences.slice(1).join(' ');
    return (
    <div style="padding: 32px 0 0;">
      <div class="r">
        <p class="synthesis-lead" set:html={linkifyText(lead, meanwhileUrlMap)} />
        {rest && (
        <details class="synthesis-details">
          <summary>Read the full analysis</summary>
          <div class="synthesis-body">
            <p class="body" style="font-size: clamp(17px, 1.8vw, 20px); line-height: 1.75; margin-bottom: 0; color: var(--ink);" set:html={linkifyText(rest, meanwhileUrlMap)} />
          </div>
        </details>
        )}
      </div>
    </div>
    );
  })()}

  <!-- COOPERATION HIGHLIGHTS — visual cards for specific stories -->
  {cooperation && cooperation.highlights && cooperation.highlights.length > 0 && (
  <div style="padding: 24px 0 0;">
    <span class="section-label section-label-cyan r" style="font-size: 13px; margin-bottom: 8px; display: block;">Stories of people showing up</span>
    <div class="coop-highlights">
      {cooperation.highlights.slice(0, 6).map((h: any) => (
        <a href={h.url || '#'} target="_blank" rel="noopener" class="coop-highlight-card" style="text-decoration: none; color: inherit;">
          <div class="coop-highlight-source">{h.source}</div>
          <div class="coop-highlight-title">{h.title}</div>
          {h.cooperation_type && <span class="coop-highlight-type">{h.cooperation_type}</span>}
        </a>
      ))}
    </div>
  </div>
  )}

  <!-- WHY THIS MATTERS -->
  {meanwhileStory.whyThisMatters && (
  <div style="padding: 24px 0 0;">
    <div class="r">
      <p class="body" style="font-size: clamp(16px, 1.7vw, 19px); line-height: 1.8; color: var(--ink-mid);" set:html={linkifyText(meanwhileStory.whyThisMatters, meanwhileUrlMap)} />
    </div>
  </div>
  )}

  <!-- WATCH FOR -->
  {meanwhileStory.watchFor && (
  <div style="padding: 24px 0 0;">
    <div class="r callout-wash callout-wash-chartreuse">
      <div class="watch-for-card" style="border-left: 4px solid var(--moss); padding: 14px 18px; background: var(--moss-wash); border-radius: 0 8px 8px 0;">
        <span style="font-family: 'Inter', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--moss-text); font-weight: 600; display: block; margin-bottom: 8px;">What to watch for</span>
        <p class="body" style="font-size: clamp(15px, 1.5vw, 17px); line-height: 1.8; color: var(--ink); margin: 0;" set:html={linkifyText(meanwhileStory.watchFor, meanwhileUrlMap)} />
      </div>
    </div>
  </div>
  )}

  <!-- SOURCE FOOTNOTES — minimal, just outlet names -->
  {cooperation && cooperation.highlights && cooperation.highlights.length > 0 && (
  <div style="padding: 24px 0 0;">
    <div class="r" style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--ink-light); line-height: 1.8;">
      Sources: {cooperation.highlights.slice(0, 6).map((h: any, i: number) => (
        <span>
          <a href={h.url || '#'} target="_blank" rel="noopener" style="color: var(--cyan-text); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px;">{h.source}</a>{i < Math.min(cooperation.highlights.length, 6) - 1 ? ', ' : ''}
        </span>
      ))}
    </div>
  </div>
  )}

  <div style="padding-bottom: 48px;"></div>
</div>
</article>
)}

</main>

<div class="section-diagonal section-diagonal--meanwhile-to-footer" aria-hidden="true"></div>

