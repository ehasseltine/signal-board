  user-select: none;
  white-space: nowrap;
  line-height: 1;
}
.sg-label-row:hover { color: var(--white); }
.sg-label-row.active { color: var(--white); font-weight: 700; }

.sg-grid {
  flex: 1;
  display: flex;
  gap: 4px;             /* column gap */
  align-items: stretch;
}

