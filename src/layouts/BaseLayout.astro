---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  dateStr?: string;
  totalStories?: number;
  sourcesReporting?: number;
}

const { title = 'Signal Board', description = 'Daily analysis from 300 sources across borders, languages, and political orientations.', dateStr, totalStories, sourcesReporting } = Astro.props;

const siteUrl = 'https://signal-board.org';
const ogImage = `${siteUrl}/og-image.png`;
const pageTitle = title === 'Signal Board' ? title : title;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const isArticle = Astro.url.pathname.startsWith('/today') || /^\/archive\/\d{4}-\d{2}-\d{2}/.test(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={description}>

  <!-- Favicons & Web App -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1B2A4B">

  <!-- Open Graph -->
  <meta property="og:type" content={isArticle ? 'article' : 'website'}>
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Signal Board: Daily news analysis from 300 sources">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Signal Board">
  <meta property="og:locale" content="en_US">
  {dateStr && (
    <meta property="article:published_time" content={dateStr}>
    <meta property="article:modified_time" content={dateStr}>
    <meta property="article:author" content="https://www.elisehasseltine.com">
  )}


  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />

  <!-- Author -->
  <meta name="author" content="Elise Hasseltine">

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="Signal Board" href={`${siteUrl}/rss.xml`}>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl}>

  <!-- JSON-LD Structured Data -->
  {isArticle && dateStr && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "headline": pageTitle,
      "description": description,
      "image": ogImage,
      "datePublished": dateStr,
      "dateModified": dateStr,
      "author": {
        "@type": "Person",
        "name": "Elise Hasseltine",
        "url": "https://www.elisehasseltine.com",
        "sameAs": "https://www.elisehasseltine.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Signal Board",
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon-192.png`
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
      },
      "isAccessibleForFree": true,
      ...(totalStories ? { "about": `Analysis of ${totalStories} articles from ${sourcesReporting || 300} sources` } : {})
    })} />
  )}
  {title.startsWith('About') && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Signal Board",
      "description": description,
      "url": canonicalUrl,
      "mainEntity": {
        "@type": "WebApplication",
        "name": "Signal Board",
        "applicationCategory": "News Analysis",
        "operatingSystem": "Web",
        "description": "Daily news analysis from 300 sources across the political spectrum, across borders, and across languages.",
        "author": {
          "@type": "Person",
          "name": "Elise Hasseltine",
          "url": "https://www.elisehasseltine.com"
        }
      }
    })} />
  )}
  {!isArticle && !title.startsWith('About') && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Signal Board",
      "url": siteUrl,
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Elise Hasseltine",
        "url": "https://www.elisehasseltine.com"
      }
    })} />
  )}

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Signal Board",
        "item": siteUrl
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": canonicalUrl
      }
    ]
  })} />

  <!-- Dataset JSON-LD (daily pages only) -->
  {isArticle && dateStr && totalStories && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": `Signal Board Daily Analysis — ${dateStr}`,
      "description": `Cross-spectrum news analysis synthesized from ${sourcesReporting || 300} sources covering ${totalStories} articles across the political spectrum, across borders, and across languages.`,
      "url": canonicalUrl,
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "creator": {
        "@type": "Person",
        "name": "Elise Hasseltine",
        "url": "https://www.elisehasseltine.com"
      },
      "datePublished": dateStr,
      "dateModified": dateStr,
      "temporalCoverage": dateStr,
      "spatialCoverage": "Global",
      "variableMeasured": [
        {
          "@type": "PropertyValue",
          "name": "Sources Reporting",
          "value": sourcesReporting || 300
        },
        {
          "@type": "PropertyValue",
          "name": "Articles Analyzed",
          "value": totalStories
        }
      ],
      "distribution": {
        "@type": "DataDownload",
        "contentUrl": `${siteUrl}/today/`,
        "encodingFormat": "text/html"
      },
      "isAccessibleForFree": true,
      "keywords": ["news analysis", "media framing", "cross-spectrum coverage", "structural forces", "cooperation", "media landscape"]
    })} />
  )}

  <!-- Fonts — consolidated to 4 families for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Abril+Fatface&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Caveat:wght@400;700&family=Inter:wght@400;500;600&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800&family=Abril+Fatface&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Caveat:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-YuA6wC0BiEc9qnBCP-hGC.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body>

<a href="#main-content" class="skip-nav">Skip to content</a>

<div id="progress" role="presentation"></div>

<slot />

<script>
  // Intersection Observer for scroll reveals
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('v'); });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('.r').forEach(el => obs.observe(el));

  // Staggered cascade for grid children (summary cards, coverage cards, framing rows)
  const gridObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const children = e.target.querySelectorAll('.cascade');
        children.forEach((child, i) => {
          child.style.transitionDelay = `${i * 50}ms`;
          child.classList.add('v');
        });
        gridObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.cascade-parent').forEach(el => gridObs.observe(el));

  setTimeout(() => {
    document.querySelectorAll('.masthead .r').forEach(el => el.classList.add('v'));
  }, 200);

  const bar = document.getElementById('progress');
  window.addEventListener('scroll', () => {
    bar.style.width = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100 + '%';
  }, { passive: true });

  let scrolled = false;
  window.addEventListener('scroll', () => {
    if (!scrolled) { scrolled = true; const c = document.querySelector('.scroll-cue'); if (c) c.style.opacity = '0'; }
  }, { passive: true });

  document.querySelectorAll('.summary-card').forEach(card => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(card.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Scroll depth tracking — fires once per threshold
  const depthMarks = [25, 50, 75, 100];
  const depthFired = new Set();
  window.addEventListener('scroll', () => {
    const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
    depthMarks.forEach(m => {
      if (pct >= m && !depthFired.has(m)) {
        depthFired.add(m);
        if (typeof gtag === 'function') gtag('event', 'scroll_depth', { depth: m });
        console.log(`[Signal Board] Scroll depth: ${m}%`);
      }
    });
  }, { passive: true });
</script>

</body>
</html>
