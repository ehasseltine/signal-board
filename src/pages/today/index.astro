  // Per-label max (for per-label normalization — gives each row full height range)
  const labelMax = {};
  LABEL_KEYS_SORTED.forEach(key => {
    labelMax[key] = Math.max(...DATES.map(d => DATA.days[d]?.[key] || 0));
  });

  // Track selected cell
  let selected = null;

  // ── Build date headers ──────────────────
  DATES.forEach((date, i) => {
    const el = document.createElement('div');
    el.className = 'sg-date-label' + (i===0 ? ' today' : '');
    // Format: Apr 7
    const d = new Date(date + 'T12:00:00Z');
    el.textContent = d.toLocaleDateString('en-US', { month:'short', day:'numeric' });
    datesRow.appendChild(el);
  });

  // ── Build label column ──────────────────
  LABEL_KEYS_SORTED.forEach(key => {
    const el = document.createElement('div');
    el.className = 'sg-label-row';
    el.textContent = DATA.labels[key].name;
    el.dataset.key = key;
    el.style.color = DATA.labels[key].color + '99';
    el.addEventListener('click', () => {
      // Clicking a label highlights all cells in that row
    });
    labelsCol.appendChild(el);
  });

  // ── Build grid: one column per date ──────
  const cells = {}; // cells[date][key] = element

  DATES.forEach((date, di) => {
    const col = document.createElement('div');
    col.className = 'sg-col';
    cells[date] = {};

    LABEL_KEYS_SORTED.forEach(key => {
      const val = DATA.days[date]?.[key] || 0;
      // Use per-label normalization so every row uses its full height range
      const pct = labelMax[key] > 0 ? (val / labelMax[key] * 100) : 0;
      const color = DATA.labels[key].color;

      const cell = document.createElement('div');
      cell.className = 'sg-cell';
      cell.dataset.date = date;
      cell.dataset.key = key;
      cell.dataset.val = val;

      const fill = document.createElement('div');
      fill.className = 'sg-cell-fill';
      fill.style.height = '0%';
      fill.style.background = `linear-gradient(0deg, ${color}DD, ${color}66)`;

      const num = document.createElement('div');
      num.className = 'sg-cell-num';
      num.style.color = color;
      num.textContent = val;

      cell.appendChild(fill);
      cell.appendChild(num);
      col.appendChild(cell);
      cells[date][key] = { cell, fill, pct, val };

      // Click handler
      cell.addEventListener('click', () => selectCell(date, key, color));
    });

    gridEl.appendChild(col);
  });

  // ── Animate bars in on scroll ────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      io.unobserve(e.target);
      // Stagger by column
      DATES.forEach((date, di) => {
        LABEL_KEYS_SORTED.forEach((key, li) => {
          const { fill, pct } = cells[date][key];
          setTimeout(() => {
            fill.style.height = Math.max(pct, 4) + '%';
          }, di * 35 + li * 8);
        });
      });
    });
  }, { threshold: 0.1 });
  io.observe(gridEl);

  // ── Sync label row heights with grid rows ─
  function syncLabelHeights() {
    const firstCol = gridEl.querySelector('.sg-col');
    if (!firstCol) return;
    const cellEls = firstCol.querySelectorAll('.sg-cell');
    const labelEls = labelsCol.querySelectorAll('.sg-label-row');
    cellEls.forEach((cellEl, i) => {
      if (labelEls[i]) {
        labelEls[i].style.height = cellEl.offsetHeight + 'px';
      }
    });
  }
  window.addEventListener('resize', syncLabelHeights);
  setTimeout(syncLabelHeights, 200);

  // ── Cell selection + detail panel ────────
  function selectCell(date, key, color) {
    // Deselect previous
    if (selected) {
      const prev = cells[selected.date]?.[selected.key];
      if (prev) prev.cell.classList.remove('selected');
      const prevLabel = labelsCol.querySelector(`[data-key="${selected.key}"]`);
      if (prevLabel) prevLabel.classList.remove('active');
    }

    selected = { date, key };
    cells[date][key].cell.classList.add('selected');
    const labelEl = labelsCol.querySelector(`[data-key="${key}"]`);
    if (labelEl) labelEl.classList.add('active');

    renderDetail(date, key, color);
  }

  function renderDetail(date, key, color) {
    const val = DATA.days[date]?.[key] || 0;
    const label = DATA.labels[key].name;
    const d = new Date(date + 'T12:00:00Z');
    const dateStr = d.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

    // Get sample articles for this date/key
    const samples = DATA.sampleArticles?.[date]?.[key] || [];

    // If no samples, show closest available date
    let articleHTML = '';
    if (samples.length) {
      articleHTML = samples.map(a => `
        <div class="sdi-article">
          <div class="sdi-src" style="color:${color}">${a.source}</div>
          <div class="sdi-title">${a.title}</div>
        </div>
      `).join('');
    } else {
      // Generic message — real articles exist in pipeline
      articleHTML = `<div class="sdi-article"><div class="sdi-title" style="color:var(--dim)">
        ${val} articles tagged "${label}" on ${dateStr}.<br>Full article list in the pipeline.
      </div></div>`;
    }

    detailEl.innerHTML = `
      <div class="sdi-header">
        <span class="sdi-label" style="color:${color}">${label}</span>
        <span class="sdi-date">${dateStr}</span>
        <span class="sdi-count" style="color:${color}">${val} articles</span>
      </div>
      <div class="sdi-articles">${articleHTML}</div>
    `;

    // Scroll detail into view
    detailEl.closest('.sg-detail').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Auto-select today's highest cell on load
  setTimeout(() => {
    const todayDate = DATES[0];
    let maxKey = 'war_and_conflict', maxVal = 0;
    LABEL_KEYS_SORTED.forEach(key => {
      const v = DATA.days[todayDate]?.[key] || 0;
      if (v > maxVal) { maxVal = v; maxKey = key; }
    });
    selectCell(todayDate, maxKey, DATA.labels[maxKey].color);
  }, 1800);
})();


/* ═════════════════════════════════════════
   3. DIVERGENCE — 37 sources, one event
   Source dots start at center, drift to
   their frame position on a spectrum.
   Score 0.901 = almost total divergence.
═════════════════════════════════════════ */


/* ═════════════════════════════════════════
   3. DIVERGENCE — fetched from pipeline
   Source dots start at center, drift to
   their frame position on a spectrum.
═════════════════════════════════════════ */
(async function initDivergence() {
  const canvas = document.getElementById('diverge-canvas');
  const tip = document.getElementById('div-tooltip');
  if (!canvas || !tip) return;
  const ctx = canvas.getContext('2d');

  const scoreEl = document.getElementById('div-score-big');
  const titleEl = document.getElementById('div-title');
  const subEl = document.getElementById('div-sub');

  // Fetch divergence data from pipeline
  let divData;
  try {
    const resp = await fetch('/data/daily/latest.json');
    const json = await resp.json();
    const ed = json.event_divergence;
    if (ed && ed.length > 0) {
      const cluster = ed[0];
      const score = cluster.divergence?.score || cluster.score || 0;
      const sourceCount = cluster.sources?.length || cluster.articles?.length || 0;
      const entities = cluster.entities || [];
      const label = cluster.structural_force || cluster.label || '';
      
      // Build article dots from sources or articles array
      const articles = [];
      const rawArticles = cluster.articles || cluster.sources || [];
      rawArticles.forEach(function(a, i) {
        const total = rawArticles.length;
        // Distribute angle evenly across 0-1 spectrum
        const angle = total > 1 ? i / (total - 1) : 0.5;
        // Color by tier
        const tierColors = {
          'national': '#FF2D55',
          'international': '#0A84FF',
          'local-regional': '#30D158',
          'specialist': '#BF5AF2',
          'analysis': '#FFD60A',
        };
        const color = tierColors[a.tier] || '#FF9500';
        articles.push({
          source: a.source || a.name || ('Source ' + i),
          color: color,
          angle: angle,
          tier: a.tier || 'national',
        });
      });

      divData = {
        score: score,
        sources: sourceCount,
        articleCount: cluster.article_count || articles.length,
        label: label,
        entities: entities,
        articles: articles,
      };

      // Update header text
      titleEl.textContent = sourceCount + ' sources. One event. Today.';
      subEl.textContent = 'The same ' + (entities[0] || label) + ' story — measured by how differently it was framed.';
    }
  } catch(e) {
    console.warn('Could not load divergence data:', e);
    titleEl.textContent = 'Divergence data unavailable';
    return;
  }

  if (!divData || !divData.articles.length) {
    titleEl.textContent = 'No divergence cluster found today';
    return;
  }

  // Animate score number
  const targetScore = divData.score;
  const io0 = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return; io0.unobserve(e.target);
      const dur=1600, start=performance.now();
      function tick(now) {
        const t=Math.min(1,(now-start)/dur), ease=easeOut(t);
        scoreEl.textContent = (ease * targetScore).toFixed(2);
        if(t<1) rAF(tick);
      }
      rAF(tick);
    });
  }, {threshold:0.5});
  io0.observe(scoreEl);

  let W, H, nodes=[], progress=0, started=false;

  function build() {
    W = canvas.offsetWidth; H = 380; canvas.height = H;
    canvas.width = W;

    const cy = H * 0.5;

    function seededRand(seed) { return ((Math.sin(seed) * 43758.5453) % 1 + 1) % 1; }
    nodes = divData.articles.map(function(a, i) {
      return {
        source: a.source,
        color: a.color,
        angle: a.angle,
        tx: 40 + a.angle * (W - 80) + (seededRand(i*7+1) - 0.5) * 40,
        ty: cy + (seededRand(i*13+3) - 0.5) * H * 0.7,
        x: W/2, y: cy,
        phase: seededRand(i*11+5) * Math.PI * 2,
      };
    });
  }

  let t=0;
  function draw(timestamp) {
    ctx.clearRect(0,0,W,H);
    t += 0.012;
    if (!started) { rAF(draw); return; }
    progress = Math.min(1, progress + 0.014);
    const ease = easeOut(progress);

    const totalDots = nodes.length;
    nodes.forEach(function(n, i) {
      const startAt = (i / totalDots) * 0.45;
      const dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      const dotEase = easeOut(dotP);
      n.x = lerp(W/2, n.tx, dotEase);
      n.y = lerp(H/2, n.ty, dotEase);
    });

    // Connection line
    if (nodes.length >= 2) {
      const xs = nodes.map(function(n){return n.x});
      const x0=Math.min.apply(null,xs)-20, x1=Math.max.apply(null,xs)+20;
      ctx.globalAlpha = ease * 0.15;
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 1; ctx.setLineDash([4,6]);
      ctx.beginPath(); ctx.moveTo(x0,H*0.42); ctx.lineTo(x1,H*0.42); ctx.stroke();
      ctx.setLineDash([]);
    }

    // Source dots
    nodes.forEach(function(n, i) {
      const startAt = (i / totalDots) * 0.45;
      const dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      if (dotP === 0) return;
      const pulse = 0.78 + 0.22 * Math.sin(t*1.3 + n.phase);
      // Glow
      const grd = ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,26);
      grd.addColorStop(0, n.color+'AA'); grd.addColorStop(1, n.color+'00');
      ctx.globalAlpha = 0.5*dotP*pulse; ctx.fillStyle = grd;
      ctx.beginPath(); ctx.arc(n.x,n.y,26,0,Math.PI*2); ctx.fill();
      // Core
      ctx.globalAlpha = dotP*pulse; ctx.fillStyle = n.color;
      ctx.beginPath(); ctx.arc(n.x,n.y,11,0,Math.PI*2); ctx.fill();
      // Label
      if (dotP > 0.7) {
        const a = (dotP-0.7)/0.3;
        ctx.globalAlpha = a*0.85; ctx.fillStyle = n.color;
        ctx.font = "bold 10px 'Space Grotesk'"; ctx.textAlign='center'; ctx.textBaseline='top';
        ctx.fillText(n.source, n.x, n.y+15);
      }
    });

    // Spectrum labels
    if (ease > 0.7) {
      const a = (ease-0.7)/0.3;
      ctx.globalAlpha = a*0.3; ctx.fillStyle='#F0F0F5';
      ctx.font="bold 9px 'Space Mono'"; ctx.textAlign='left'; ctx.textBaseline='middle';
      ctx.fillText('← FRAME A', 16, H*0.5);
      ctx.textAlign='right';
      ctx.fillText('FRAME B →', W-16, H*0.5);
      ctx.globalAlpha = a*0.06; ctx.strokeStyle='#ffffff';
      ctx.lineWidth=1; ctx.setLineDash([4,6]);
      ctx.beginPath(); ctx.moveTo(40, H*0.5); ctx.lineTo(W-40, H*0.5); ctx.stroke();
      ctx.setLineDash([]);
    }
    ctx.globalAlpha=1; ctx.textAlign='left'; ctx.textBaseline='alphabetic';
    rAF(draw);
  }

  // Replay animation on scroll into view
  const io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        build();
        progress = 0;
        nodes.forEach(function(n) { n.x = W/2; n.y = H/2; });
        started = true;
        rAF(draw);
      }
    });
  }, { threshold: 0.2 });
  io.observe(canvas.closest('.diverge-sec'));
  window.addEventListener('resize', function() { if (started) { build(); progress=0; } });

  canvas.addEventListener('mousemove', function(e) {
    const rect=canvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)*(W/rect.width);
    const my=(e.clientY-rect.top)*(280/rect.height);
    const hit=nodes.find(function(n){return Math.hypot(mx-n.x,my-n.y)<18});
    if (hit) {
      tip.style.display='block';
      tip.style.left=(e.clientX+14)+'px'; tip.style.top=(e.clientY-8)+'px';
      tip.innerHTML='<div class="tt-name" style="color:'+hit.color+'">'+hit.source+'</div>';
    } else tip.style.display='none';
  });
  canvas.addEventListener('mouseleave',function(){tip.style.display='none'});
})();


/* ─── NAV scroll state ──────────────────── */
(function(){
  var nav=document.querySelector('.nav');
  window.addEventListener('scroll',function(){nav.classList.toggle('solid',window.scrollY>80)},{passive:true});
})();
</script>

