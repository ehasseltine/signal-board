---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{editorial?.accessible_headline || 'Signal Board'} | Signal Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
/* SIGNAL BOARD — THE SEISMOGRAPH */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg:    #08080E;
  --bg2:   #10101A;
  --bg3:   #18182A;
  --white: #F0F0F5;
  --dim:   rgba(240,240,245,0.4);
  --faint: rgba(240,240,245,0.12);
  --yellow:#FFD60A;
  --mono:  'Space Mono', monospace;
  --sans:  'Space Grotesk', sans-serif;
  --ease:  cubic-bezier(0.16, 1, 0.3, 1);
}
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--white); font-family: var(--sans);
       overflow-x: hidden; -webkit-font-smoothing: antialiased; }

.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 48px; display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px;
  background: rgba(8,8,14,0); transition: background 0.3s;
}
.nav.solid { background: rgba(8,8,14,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid var(--faint); }
.nav-logo { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--yellow); letter-spacing: 0.15em; }
.nav-right { display: flex; gap: 20px; align-items: center; }
.nav-right a { font-family: var(--mono); font-size: 11px; color: var(--dim); text-decoration: none; letter-spacing: 0.06em; transition: color 0.15s; }
.nav-right a:hover { color: var(--white); }
.nav-sub { border: 1px solid rgba(255,214,10,0.35); padding: 4px 12px; border-radius: 100px; color: var(--yellow) !important; }

.hero {
  position: relative; height: 100vh; min-height: 560px;
  display: flex; flex-direction: column; justify-content: flex-end;
  overflow: hidden;
}
#gol-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
.hero-content {
  position: relative; z-index: 2;
  padding: 0 32px clamp(56px, 8vh, 88px);
}
.hero-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--yellow); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 16px; }
.hero-hed {
  font-size: clamp(44px, 7.5vw, 108px); font-weight: 700;
  line-height: 0.95; letter-spacing: -0.04em;
  margin-bottom: clamp(24px, 4vh, 40px);
}
.hero-hed em { font-style: normal; background: linear-gradient(90deg, #FF9500, #FF2D55); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-stats { display: flex; gap: 36px; flex-wrap: wrap; }
.hs { display: flex; flex-direction: column; gap: 3px; }
.hs-n { font-family: var(--mono); font-size: clamp(28px, 3.5vw, 42px); font-weight: 700; line-height: 1; }
.hs-l { font-family: var(--mono); font-size: 9px; color: var(--faint); letter-spacing: 0.1em; text-transform: uppercase; }
.hero-scroll { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); font-family: var(--mono); font-size: 11px; color: var(--faint); animation: bob 2.4s ease-in-out infinite; }
@keyframes bob { 0%,100%{opacity:0.3;transform:translateX(-50%) translateY(0)} 50%{opacity:0.7;transform:translateX(-50%) translateY(6px)} }

.seismograph-sec {
  padding: 48px 0 0;
  background: var(--bg);
  min-height: 100vh;
}
.sg-header { padding: 0 32px 28px; }
.sg-title { font-family: var(--mono); font-size: clamp(22px, 3vw, 34px); font-weight: 700; letter-spacing: -0.02em; color: var(--white); margin-bottom: 6px; }
.sg-sub   { font-family: var(--mono); font-size: 11px; color: var(--dim); letter-spacing: 0.05em; }

.sg-unified {
  display: grid;
  padding: 0 16px;
  gap: 3px;
}
.sg-corner { }
.sg-date-label {
  text-align: center;
  font-family: var(--mono); font-size: 9px; color: var(--faint);
  letter-spacing: 0.05em; text-transform: uppercase;
  padding-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
}
.sg-date-label.today { color: var(--yellow); }
.sg-label-row {
  display: flex; align-items: center; justify-content: flex-end;
  padding-right: 10px;
  font-family: var(--mono); font-size: 9px; color: var(--dim);
  letter-spacing: 0.04em; text-transform: uppercase;
  cursor: pointer; transition: color 0.15s;
  user-select: none; min-height: 22px;
}
.sg-label-row:hover { color: var(--white); }
.sg-label-row.active { color: var(--white); font-weight: 700; }
.sg-cell {
  position: relative;
  background: var(--bg3);
  border-radius: 2px;
  cursor: pointer;
  overflow: hidden;
  transition: transform 0.12s var(--ease), box-shadow 0.12s;
  min-height: 22px;
}
.sg-cell:hover { transform: scale(1.06); z-index: 10; }
.sg-cell.selected { box-shadow: 0 0 0 2px var(--yellow); z-index: 20; }
.sg-cell-fill {
  position: absolute; bottom: 0; left: 0; right: 0;
  border-radius: 2px;
  transition: height 1.2s var(--ease), opacity 0.3s;
  opacity: 0.85;
}
.sg-cell:hover .sg-cell-fill { opacity: 1; }
.sg-cell-num {
  position: absolute; bottom: 2px; left: 0; right: 0;
  text-align: center;
  font-family: var(--mono); font-size: 8px; font-weight: 700;
  color: rgba(0,0,0,0.7);
  opacity: 0; transition: opacity 0.15s;
  pointer-events: none; z-index: 5;
}
.sg-cell:hover .sg-cell-num { opacity: 1; }

.sg-detail {
  margin-top: 12px;
  padding: 0 16px;
  min-height: 180px;
}
.sg-detail-inner {
  background: var(--bg2);
  border: 1px solid var(--faint);
  border-radius: 10px;
  padding: 24px;
  transition: all 0.3s var(--ease);
}
.sdi-hint { font-family: var(--mono); font-size: 11px; color: var(--faint); }
.sdi-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
.sdi-label { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--white); }
.sdi-date  { font-family: var(--mono); font-size: 11px; color: var(--faint); }
.sdi-count { font-family: var(--mono); font-size: 11px; font-weight: 700; }
.sdi-articles { display: flex; flex-wrap: wrap; gap: 8px; }
.sdi-article {
  background: var(--bg3); border: 1px solid var(--faint); border-radius: 6px;
  padding: 10px 14px; max-width: 360px;
  cursor: default; transition: border-color 0.15s;
}
.sdi-article:hover { border-color: rgba(255,255,255,0.2); }
.sdi-src { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
.sdi-title { font-size: 12px; line-height: 1.5; color: var(--dim); }

.diverge-sec {
  padding: 64px 32px;
  background: var(--bg2);
  border-top: 1px solid var(--faint);
}
.div-header {
  display: flex; align-items: baseline; gap: 20px; flex-wrap: wrap;
  margin-bottom: 32px;
}
.div-score-big {
  font-family: var(--mono); font-size: clamp(56px, 8vw, 96px); font-weight: 700;
  line-height: 1; letter-spacing: -0.04em; color: var(--yellow);
}
.div-title { font-family: var(--mono); font-size: clamp(16px, 2vw, 22px); font-weight: 700; color: var(--white); margin-bottom: 4px; }
.div-sub   { font-family: var(--mono); font-size: 11px; color: var(--dim); }
#diverge-canvas { display: block; width: 100%; height: 380px; }

.tooltip {
  position: fixed; z-index: 500; display: none;
  background: rgba(8,8,14,0.97); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px; padding: 10px 14px; max-width: 260px;
  pointer-events: none;
}
.tt-name  { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--white); margin-bottom: 3px; }
.tt-meta  { font-family: var(--mono); font-size: 10px; color: var(--yellow); margin-bottom: 3px; }
.tt-text  { font-size: 11px; color: var(--dim); line-height: 1.5; font-style: italic; }

.footer { background: var(--bg); border-top: 1px solid var(--faint); padding: 28px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.f-logo { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--white); letter-spacing: 0.1em; }
.f-meta { font-family: var(--mono); font-size: 10px; color: var(--faint); }
.f-meta a { color: var(--faint); text-decoration: none; }
.f-cta  { font-family: var(--mono); font-size: 11px; color: var(--yellow); text-decoration: none; border-bottom: 1px solid rgba(255,214,10,0.3); }

@media (max-width: 600px) {
  .sg-unified { padding: 0 8px; }
  .sg-label-row { font-size: 7px; padding-right: 6px; }
  .hero-stats { gap: 20px; }
}
  </style>
</head>
<body>

<nav class="nav">
  <span class="nav-logo">SB</span>
  <div class="nav-right">
    <a href="/archive/">Archive</a>
    <a href="/about/">About</a>
    <a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" class="nav-sub">Subscribe</a>
  </div>
</nav>

<section class="hero">
  <canvas id="gol-canvas"></canvas>
  <div class="hero-content">
    <div class="hero-eyebrow">Signal Board &middot; {dateStr}</div>
    <h1 class="hero-hed"><em>{editorial?.accessible_headline?.split(' ').slice(0,4).join(' ') || "Today's Signal"}</em></h1>
    <div class="hero-stats">
      <div class="hs"><span class="hs-n" data-target={String(totalStories)}>0</span><span class="hs-l">articles</span></div>
      <div class="hs"><span class="hs-n" data-target={String(sourcesReporting || 300)}>0</span><span class="hs-l">sources</span></div>
      <div class="hs"><span class="hs-n" data-target="15">0</span><span class="hs-l">topics</span></div>
    </div>
  </div>
  <div class="hero-scroll">scroll &darr;</div>
</section>

<section class="seismograph-sec" id="seismograph-sec">
  <div class="sg-header">
    <div class="sg-title">The Seismograph</div>
    <div class="sg-sub">Each column is a day. Each row is a topic. Height = how much was covered. Tap any cell.</div>
  </div>
  <div class="sg-unified" id="sg-unified"></div>
  <div class="sg-detail" id="sg-detail">
    <div class="sg-detail-inner" id="sg-detail-inner">
      <div class="sdi-hint">Tap any cell to see what was covered</div>
    </div>
  </div>
</section>

<section class="diverge-sec" id="diverge-sec">
  <div class="div-header">
    <span class="div-score-big" id="div-score-big">0.00</span>
    <div class="div-header-text">
      <div class="div-title" id="div-title">Loading divergence data...</div>
      <div class="div-sub" id="div-sub"></div>
    </div>
  </div>
  <canvas id="diverge-canvas"></canvas>
  <div id="div-tooltip" class="tooltip"></div>
</section>

<footer class="footer">
  <span class="f-logo">Signal Board</span>
  <span class="f-meta">300 sources &middot; daily &middot; no algorithm &middot; <a href="https://www.elisehasseltine.com/">Elise Hasseltine</a></span>
  <a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" class="f-cta">Subscribe &rarr;</a>
</footer>

<script is:inline>
/* ══════════════════════════════════════════
   SIGNAL BOARD — THE SEISMOGRAPH
   Dynamic data. 7 days. 15 labels. 300 sources.
══════════════════════════════════════════ */

var LABELS = {
  war_and_conflict:      { name: 'War & Conflict',     color: '#FF2D55' },
  whos_in_charge:        { name: "Who's in Charge",    color: '#FF9500' },
  rules_and_courts:      { name: 'Rules & Courts',     color: '#FFD60A' },
  money_and_prices:      { name: 'Money & Prices',     color: '#30D158' },
  oil_and_energy:        { name: 'Oil & Energy',       color: '#FF6B00' },
  global_relations:      { name: 'Global Relations',   color: '#0A84FF' },
  rights_and_justice:    { name: 'Rights & Justice',   color: '#BF5AF2' },
  ai_and_technology:     { name: 'AI & Technology',    color: '#00D4FF' },
  communities:           { name: 'Communities',        color: '#34C759' },
  health:                { name: 'Health',             color: '#5AC8FA' },
  work_and_workers:      { name: 'Work & Workers',     color: '#FF9F0A' },
  media_and_information: { name: 'Media & Info',       color: '#AF52DE' },
  the_environment:       { name: 'The Environment',    color: '#32D74B' },
  food_and_land:         { name: 'Food & Land',        color: '#FFD426' },
  people_power:          { name: 'People Power',       color: '#FF375F' }
};
var LABEL_KEYS = Object.keys(LABELS);

/* ─── Utilities ─── */
var rAF = function(fn) { return requestAnimationFrame(fn); };
var lerp = function(a, b, t) { return a + (b - a) * t; };
var easeOut = function(t) { return 1 - Math.pow(1 - t, 3); };
var easeOutQuart = function(t) { return 1 - Math.pow(1 - t, 4); };
function seededRand(seed) { return ((Math.sin(seed) * 43758.5453) % 1 + 1) % 1; }

/* ─── Map domain_distribution keys to internal 15-label keys ─── */
function mapDomainDist(dom) {
  var MAP = {
    /* Display names (15-label) */
    'War & Conflict': 'war_and_conflict',
    "Who's in Charge": 'whos_in_charge',
    'Rules & Courts': 'rules_and_courts',
    'Money & Prices': 'money_and_prices',
    'Oil & Energy': 'oil_and_energy',
    'Global Relations': 'global_relations',
    'Rights & Justice': 'rights_and_justice',
    'AI & Technology': 'ai_and_technology',
    'Communities': 'communities',
    'Health': 'health',
    'Work & Workers': 'work_and_workers',
    'Media & Info': 'media_and_information',
    'Media & Information': 'media_and_information',
    'The Environment': 'the_environment',
    'Food & Land': 'food_and_land',
    'People Power': 'people_power',
    /* Old 10-label names */
    'Security': 'war_and_conflict',
    'Governance': 'whos_in_charge',
    'Legal': 'rules_and_courts',
    'Economics': 'money_and_prices',
    'Geopolitics': 'global_relations',
    'Information': 'media_and_information',
    'Climate': 'the_environment',
    'Labor': 'work_and_workers',
    'AI': 'ai_and_technology',
    'Politics': 'whos_in_charge'
  };
  var counts = {};
  LABEL_KEYS.forEach(function(k) { counts[k] = 0; });
  Object.keys(dom).forEach(function(rawKey) {
    var internal = MAP[rawKey] || rawKey;
    if (counts.hasOwnProperty(internal)) {
      counts[internal] += dom[rawKey];
    }
  });
  return counts;
}

/* ─── Cache for fetched daily JSON ─── */
var dayJsonCache = {};

function fetchDayJson(dateStr) {
  if (dayJsonCache[dateStr]) return Promise.resolve(dayJsonCache[dateStr]);
  return fetch('/data/daily/' + dateStr + '.json')
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(d) { if (d) dayJsonCache[dateStr] = d; return d; })
    .catch(function() { return null; });
}

/* ═════════════════════════════════════════
   BOOT — async, fetches data then inits
═════════════════════════════════════════ */
(async function boot() {
  /* Fire non-data-dependent inits immediately */
  initGoL();
  initCountUps();
  initNav();

  /* Fetch today's data */
  var todayData = null;
  try {
    var resp = await fetch('/data/daily/latest.json');
    todayData = await resp.json();
  } catch(e) {
    console.error('Failed to load latest.json', e);
    return;
  }
  dayJsonCache[todayData.date] = todayData;

  var todayDate = todayData.date;

  /* Build 7-day date range (today + 6 back) */
  var dates = [todayDate];
  var d = new Date(todayDate + 'T12:00:00Z');
  for (var i = 1; i < 7; i++) {
    var prev = new Date(d);
    prev.setUTCDate(prev.getUTCDate() - i);
    dates.push(prev.toISOString().split('T')[0]);
  }

  /* Fetch older days in parallel */
  var fetches = dates.slice(1).map(function(ds) { return fetchDayJson(ds); });
  await Promise.all(fetches);

  /* Build dayData: { date: { label: count } } */
  var dayData = {};
  var validDates = [];
  dates.forEach(function(ds) {
    var json = dayJsonCache[ds];
    if (json && json.summary && json.summary.domain_distribution) {
      dayData[ds] = mapDomainDist(json.summary.domain_distribution);
      dayData[ds].total = json.summary.total_stories || 0;
      validDates.push(ds);
    }
  });

  if (validDates.length === 0) {
    console.error('No valid day data found');
    return;
  }

  initSeismograph(validDates, dayData);
  initDivergence(todayData);
})();


/* ═════════════════════════════════════════
   1. GAME OF LIFE — hero canvas
═════════════════════════════════════════ */
function initGoL() {
  var canvas = document.getElementById('gol-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var SZ = 13;
  var COLS = ['#FF2D55','#FF9500','#30D158','#0A84FF','#BF5AF2','#FFD60A'];
  var W, H, cols, rows, grid, next, colors;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cols = Math.ceil(W/SZ)+1; rows = Math.ceil(H/SZ)+1;
    grid = new Uint8Array(cols*rows); next = new Uint8Array(cols*rows);
    colors = new Uint8Array(cols*rows);
    for (var i=0;i<grid.length;i++) { grid[i]=Math.random()<0.2?1:0; colors[i]=Math.floor(Math.random()*6); }
  }

  function step() {
    for (var r=0;r<rows;r++) for (var c=0;c<cols;c++) {
      var n=0, idx=r*cols+c;
      for (var dr=-1;dr<=1;dr++) for (var dc=-1;dc<=1;dc++) {
        if(!dr&&!dc) continue;
        n+=grid[((r+dr+rows)%rows)*cols+((c+dc+cols)%cols)];
      }
      if (grid[idx]) next[idx]=(n===2||n===3)?1:0;
      else { next[idx]=n===3?1:0; if(n===3) colors[idx]=Math.floor(Math.random()*6); }
    }
    var tmp=grid; grid=next; next=tmp;
  }

  var fr=0;
  function draw() {
    ctx.clearRect(0,0,W,H);
    for (var r=0;r<rows;r++) for (var c=0;c<cols;c++) {
      if (!grid[r*cols+c]) continue;
      ctx.globalAlpha=0.48; ctx.fillStyle=COLS[colors[r*cols+c]];
      ctx.beginPath(); ctx.roundRect(c*SZ+1,r*SZ+1,SZ-2,SZ-2,2); ctx.fill();
    }
    ctx.globalAlpha=1;
    var g=ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0,'rgba(8,8,14,0.35)'); g.addColorStop(0.45,'rgba(8,8,14,0.55)'); g.addColorStop(1,'rgba(8,8,14,0.96)');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
    fr++; if(fr%4===0) step();
    rAF(draw);
  }
  resize(); draw();
  window.addEventListener('resize', resize);
}


/* ═════════════════════════════════════════
   Count-up animation for hero stats
═════════════════════════════════════════ */
function initCountUps() {
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if(!e.isIntersecting) return; io.unobserve(e.target);
      var target=parseInt(e.target.dataset.target), dur=1400, start=performance.now();
      function tick(now) {
        var t=Math.min(1,(now-start)/dur), ease=easeOutQuart(t);
        e.target.textContent=Math.round(ease*target).toLocaleString();
        if(t<1) rAF(tick);
      }
      rAF(tick);
    });
  }, {threshold:0.5});
  document.querySelectorAll('.hs-n[data-target]').forEach(function(el){io.observe(el);});
}


/* ═════════════════════════════════════════
   2. THE SEISMOGRAPH
   Unified CSS Grid: labels + dates + bars
   all in one container so columns align.
═════════════════════════════════════════ */
function initSeismograph(dates, dayData) {
  var gridEl = document.getElementById('sg-unified');
  var detailEl = document.getElementById('sg-detail-inner');
  if (!gridEl) return;

  var NUM_COLS = dates.length;
  /* grid-template-columns: 120px repeat(N, 1fr) */
  gridEl.style.gridTemplateColumns = '120px repeat(' + NUM_COLS + ', 1fr)';

  /* Per-label max for normalization */
  var labelMax = {};
  LABEL_KEYS.forEach(function(key) {
    labelMax[key] = 0;
    dates.forEach(function(ds) {
      var v = dayData[ds] ? (dayData[ds][key] || 0) : 0;
      if (v > labelMax[key]) labelMax[key] = v;
    });
  });

  var selected = null;
  var cells = {};

  /* ── Row 1: corner + date headers ── */
  var corner = document.createElement('div');
  corner.className = 'sg-corner';
  gridEl.appendChild(corner);

  dates.forEach(function(ds, i) {
    var el = document.createElement('div');
    el.className = 'sg-date-label' + (i === 0 ? ' today' : '');
    var dt = new Date(ds + 'T12:00:00Z');
    el.textContent = dt.toLocaleDateString('en-US', { month:'short', day:'numeric' });
    gridEl.appendChild(el);
  });

  /* ── Rows 2+: label + cells ── */
  LABEL_KEYS.forEach(function(key) {
    /* Label cell */
    var labelEl = document.createElement('div');
    labelEl.className = 'sg-label-row';
    labelEl.textContent = LABELS[key].name;
    labelEl.dataset.key = key;
    labelEl.style.color = LABELS[key].color + '99';
    gridEl.appendChild(labelEl);

    /* Data cells for each date */
    dates.forEach(function(ds, di) {
      var val = dayData[ds] ? (dayData[ds][key] || 0) : 0;
      var pct = labelMax[key] > 0 ? (val / labelMax[key] * 100) : 0;
      var color = LABELS[key].color;

      var cell = document.createElement('div');
      cell.className = 'sg-cell';
      cell.dataset.date = ds;
      cell.dataset.key = key;
      cell.dataset.val = val;

      var fill = document.createElement('div');
      fill.className = 'sg-cell-fill';
      fill.style.height = '0%';
      fill.style.background = 'linear-gradient(0deg, ' + color + 'DD, ' + color + '66)';

      var num = document.createElement('div');
      num.className = 'sg-cell-num';
      num.style.color = color;
      num.textContent = val;

      cell.appendChild(fill);
      cell.appendChild(num);
      gridEl.appendChild(cell);

      if (!cells[ds]) cells[ds] = {};
      cells[ds][key] = { cell: cell, fill: fill, pct: pct, val: val };

      cell.addEventListener('click', function() { selectCell(ds, key, color); });
    });
  });

  /* ── Animate bars on scroll ── */
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      io.unobserve(e.target);
      dates.forEach(function(ds, di) {
        LABEL_KEYS.forEach(function(key, li) {
          var c = cells[ds] && cells[ds][key];
          if (!c) return;
          setTimeout(function() {
            c.fill.style.height = Math.max(c.pct, 4) + '%';
          }, di * 35 + li * 8);
        });
      });
    });
  }, { threshold: 0.1 });
  io.observe(gridEl);

  /* ── Cell selection ── */
  function selectCell(date, key, color) {
    if (selected) {
      var prev = cells[selected.date] && cells[selected.date][selected.key];
      if (prev) prev.cell.classList.remove('selected');
      var prevLabel = gridEl.querySelector('.sg-label-row[data-key="' + selected.key + '"]');
      if (prevLabel) prevLabel.classList.remove('active');
    }
    selected = { date: date, key: key };
    cells[date][key].cell.classList.add('selected');
    var labelEl = gridEl.querySelector('.sg-label-row[data-key="' + key + '"]');
    if (labelEl) labelEl.classList.add('active');
    renderDetail(date, key, color);
  }

  /* ── Detail panel — fetches real articles from daily JSON ── */
  function renderDetail(date, key, color) {
    var val = dayData[date] ? (dayData[date][key] || 0) : 0;
    var label = LABELS[key].name;
    var dt = new Date(date + 'T12:00:00Z');
    var dateStr = dt.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

    /* Show loading state */
    detailEl.innerHTML = '<div class="sdi-header">' +
      '<span class="sdi-label" style="color:' + color + '">' + label + '</span>' +
      '<span class="sdi-date">' + dateStr + '</span>' +
      '<span class="sdi-count" style="color:' + color + '">' + val + ' articles</span>' +
      '</div><div class="sdi-articles"><div class="sdi-hint">Loading articles...</div></div>';

    /* Fetch articles from the daily JSON */
    fetchDayJson(date).then(function(json) {
      var articles = [];
      if (json) {
        /* Match articles by force_tag keywords relevant to each label */
        var keywordMap = {
          'war_and_conflict': ['military', 'warfare', 'war', 'conflict', 'combat', 'attack', 'strike', 'weapon', 'defense', 'defence', 'hostage', 'escalat'],
          'whos_in_charge': ['governance', 'politic', 'executive', 'authoritarian', 'president', 'administration', 'leadership', 'instability', 'personnel', 'partisan', 'loyalty', 'accountability'],
          'rules_and_courts': ['legal', 'court', 'law', 'judicial', 'enforcement', 'prosecution', 'justice system', 'ruling', 'verdict', 'traffic law'],
          'money_and_prices': ['econom', 'financial', 'market', 'price', 'inflation', 'fiscal', 'monetary', 'trade', 'tariff', 'collapse', 'recession'],
          'oil_and_energy': ['energy', 'oil', 'gas', 'fuel', 'pipeline', 'resource vulnerability'],
          'global_relations': ['geopolit', 'diplomacy', 'diplomatic', 'international', 'proxy', 'sanction', 'alliance', 'foreign'],
          'rights_and_justice': ['rights', 'justice', 'civil', 'freedom', 'discrimination', 'equality', 'repression'],
          'ai_and_technology': ['ai', 'artificial', 'technology', 'automat', 'algorithm', 'digital', 'cyber', 'creative worker'],
          'communities': ['communit', 'local', 'neighborhood', 'civic', 'volunteer'],
          'health': ['health', 'medical', 'hospital', 'disease', 'pandemic', 'vaccine'],
          'work_and_workers': ['labor', 'worker', 'employment', 'wage', 'union', 'job', 'workforce'],
          'media_and_information': ['media', 'information', 'journalism', 'press', 'misinformation', 'propaganda'],
          'the_environment': ['climate', 'environment', 'pollution', 'conservation', 'emission', 'renewable'],
          'food_and_land': ['food', 'agriculture', 'farm', 'land', 'crop', 'hunger', 'supply chain'],
          'people_power': ['protest', 'movement', 'activism', 'grassroot', 'demonstration', 'solidarity', 'cooperative']
        };

        var keywords = keywordMap[key] || [key];

        function matchesLabel(forceText) {
          var f = forceText.toLowerCase();
          return keywords.some(function(kw) { return f.indexOf(kw) !== -1; });
        }

        /* Search top_stories by structural_force */
        (json.top_stories || []).forEach(function(story) {
          if (matchesLabel(story.structural_force || '')) {
            (story.articles || []).forEach(function(a) {
              if (a.source && a.title && articles.length < 8) {
                articles.push({ source: a.source, title: a.title, url: a.url || '', tier: a.tier || '' });
              }
            });
          }
        });

        /* Also search by individual article force_tag */
        if (articles.length < 4) {
          (json.top_stories || []).forEach(function(story) {
            (story.articles || []).forEach(function(a) {
              if (a.source && a.title && articles.length < 8 && matchesLabel(a.force_tag || '')) {
                var exists = articles.some(function(e) { return e.source === a.source; });
                if (!exists) articles.push({ source: a.source, title: a.title, url: a.url || '', tier: a.tier || '' });
              }
            });
          });
        }

        /* Search narrative_divergence */
        if (articles.length < 4) {
          (json.narrative_divergence || []).forEach(function(nd) {
            if (matchesLabel(nd.structural_force || '')) {
              (nd.articles || []).forEach(function(a) {
                if (a.source && a.title && articles.length < 8) {
                  var exists = articles.some(function(e) { return e.source === a.source; });
                  if (!exists) articles.push({ source: a.source, title: a.title, url: a.url || '', tier: a.tier || '' });
                }
              });
            }
          });
        }

        /* Search event_divergence */
        if (articles.length < 4) {
          (json.event_divergence || []).forEach(function(ed) {
            if (matchesLabel(ed.structural_force || '')) {
              (ed.articles || []).forEach(function(a) {
                if (a.source && a.title && articles.length < 8) {
                  var exists = articles.some(function(e) { return e.source === a.source; });
                  if (!exists) articles.push({ source: a.source, title: a.title, url: a.url || '', tier: a.tier || '' });
                }
              });
            }
          });
        }
      }

      var articleHTML = '';
      if (articles.length > 0) {
        articleHTML = articles.map(function(a) {
          var tierBadge = a.tier ? '<span style="font-family:var(--mono);font-size:8px;color:var(--faint);text-transform:uppercase;margin-left:6px;">' + a.tier + '</span>' : '';
          return '<div class="sdi-article">' +
            '<div class="sdi-src" style="color:' + color + '">' + a.source + tierBadge + '</div>' +
            '<div class="sdi-title">' + a.title + '</div>' +
            '</div>';
        }).join('');
      } else {
        articleHTML = '<div class="sdi-article"><div class="sdi-title" style="color:var(--dim)">' +
          val + ' articles tagged "' + label + '" on ' + dateStr + '.</div></div>';
      }

      detailEl.innerHTML = '<div class="sdi-header">' +
        '<span class="sdi-label" style="color:' + color + '">' + label + '</span>' +
        '<span class="sdi-date">' + dateStr + '</span>' +
        '<span class="sdi-count" style="color:' + color + '">' + val + ' articles</span>' +
        '</div><div class="sdi-articles">' + articleHTML + '</div>';
    });

    detailEl.closest('.sg-detail').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* Auto-select today's highest cell */
  setTimeout(function() {
    var todayDate = dates[0];
    var maxKey = 'war_and_conflict', maxVal = 0;
    LABEL_KEYS.forEach(function(key) {
      var v = dayData[todayDate] ? (dayData[todayDate][key] || 0) : 0;
      if (v > maxVal) { maxVal = v; maxKey = key; }
    });
    selectCell(todayDate, maxKey, LABELS[maxKey].color);
  }, 1800);
}


/* ═════════════════════════════════════════
   3. DIVERGENCE — sources on a spectrum
═════════════════════════════════════════ */
function initDivergence(todayData) {
  var canvas = document.getElementById('diverge-canvas');
  var tip = document.getElementById('div-tooltip');
  var scoreEl = document.getElementById('div-score-big');
  var titleEl = document.getElementById('div-title');
  var subEl = document.getElementById('div-sub');
  if (!canvas || !tip) return;
  var ctx = canvas.getContext('2d');

  /* Find best divergence cluster — try event_divergence first, then scan older days */
  var cluster = null;
  var divergenceScore = 0;

  if (todayData.event_divergence && todayData.event_divergence.length > 0) {
    cluster = todayData.event_divergence[0];
    divergenceScore = cluster.divergence ? cluster.divergence.score : 0;
  }

  /* If today has no event_divergence, scan cached days */
  if (!cluster) {
    var cached = Object.keys(dayJsonCache);
    for (var i = 0; i < cached.length; i++) {
      var dj = dayJsonCache[cached[i]];
      if (dj && dj.event_divergence && dj.event_divergence.length > 0) {
        cluster = dj.event_divergence[0];
        divergenceScore = cluster.divergence ? cluster.divergence.score : 0;
        break;
      }
    }
  }

  /* Build nodes from cluster data */
  var TIER_ORDER = { 'national': 0, 'international': 1, 'local-regional': 2, 'specialist': 3, 'analysis': 4 };
  var PALETTE = {
    'national': '#FF2D55',
    'international': '#0A84FF',
    'local-regional': '#30D158',
    'specialist': '#BF5AF2',
    'analysis': '#FFD60A'
  };

  var sourceNodes = [];
  var FORCE_DISPLAY = {
    'war_and_conflict': 'War & Conflict',
    'military escalation': 'Military Escalation',
    'global_relations': 'Global Relations',
    'whos_in_charge': "Who's in Charge",
    'rules_and_courts': 'Rules & Courts',
    'money_and_prices': 'Money & Prices',
    'oil_and_energy': 'Oil & Energy',
    'rights_and_justice': 'Rights & Justice',
    'ai_and_technology': 'AI & Technology',
    'communities': 'Communities',
    'health': 'Health',
    'work_and_workers': 'Work & Workers',
    'media_and_information': 'Media & Info',
    'the_environment': 'The Environment',
    'food_and_land': 'Food & Land',
    'people_power': 'People Power'
  };

  if (cluster) {
    var sources = cluster.sources || [];
    var articles = cluster.articles || [];
    var articleLookup = {};
    articles.forEach(function(a) { articleLookup[a.source] = a; });

    sources.forEach(function(src, i) {
      var art = articleLookup[src] || {};
      var tier = art.tier || 'national';
      sourceNodes.push({
        source: src,
        title: art.title || '',
        tier: tier,
        color: PALETTE[tier] || '#FFD60A',
        angle: sources.length > 1 ? i / (sources.length - 1) : 0.5
      });
    });

    /* Also include articles not in sources list */
    articles.forEach(function(a) {
      var exists = sourceNodes.some(function(n) { return n.source === a.source; });
      if (!exists) {
        var tier = a.tier || 'national';
        sourceNodes.push({
          source: a.source,
          title: a.title || '',
          tier: tier,
          color: PALETTE[tier] || '#FFD60A',
          angle: sourceNodes.length / (sources.length || 1)
        });
      }
    });

    /* Sort by tier */
    sourceNodes.sort(function(a, b) {
      return (TIER_ORDER[a.tier] || 9) - (TIER_ORDER[b.tier] || 9);
    });
    /* Reassign angles after sort */
    sourceNodes.forEach(function(n, i) {
      n.angle = sourceNodes.length > 1 ? i / (sourceNodes.length - 1) : 0.5;
    });

    var forceLabel = FORCE_DISPLAY[cluster.structural_force] || cluster.structural_force || 'Unknown';
    titleEl.textContent = sourceNodes.length + ' sources. One event. ' + forceLabel + '.';
    subEl.textContent = 'The same story from ' + forceLabel.toLowerCase() + ' coverage, measured by how differently it was framed.';
  } else {
    /* No divergence data — show fallback message */
    titleEl.textContent = 'No divergence clusters today.';
    subEl.textContent = 'Event-level divergence analysis requires multiple sources covering the same event.';
    scoreEl.textContent = '—';
    return;
  }

  /* Animate score */
  var targetScore = divergenceScore;
  var io0 = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return; io0.unobserve(e.target);
      var dur = 1600, start = performance.now();
      function tick(now) {
        var t = Math.min(1, (now - start) / dur), ease = easeOut(t);
        scoreEl.textContent = (ease * targetScore).toFixed(2);
        if (t < 1) rAF(tick);
      }
      rAF(tick);
    });
  }, { threshold: 0.5 });
  io0.observe(scoreEl);

  var W, H, nodes = [], progress = 0, started = false;

  function build() {
    W = canvas.offsetWidth; H = 380;
    canvas.width = W; canvas.height = H;
    var cy = H * 0.5;

    nodes = sourceNodes.map(function(a, i) {
      return {
        source: a.source,
        title: a.title,
        color: a.color,
        tier: a.tier,
        tx: 40 + a.angle * (W - 80) + (seededRand(i * 7 + 1) - 0.5) * 40,
        ty: cy + (seededRand(i * 13 + 3) - 0.5) * H * 0.7,
        x: W / 2, y: cy,
        phase: seededRand(i * 11 + 5) * Math.PI * 2
      };
    });
  }

  var t = 0;
  function draw() {
    ctx.clearRect(0, 0, W, H);
    t += 0.012;
    if (!started) { rAF(draw); return; }
    progress = Math.min(1, progress + 0.014);
    var ease = easeOut(progress);
    var totalDots = nodes.length;

    nodes.forEach(function(n, i) {
      var startAt = (i / totalDots) * 0.45;
      var dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      var dotEase = easeOut(dotP);
      n.x = lerp(W / 2, n.tx, dotEase);
      n.y = lerp(H / 2, n.ty, dotEase);
    });

    /* Connection line */
    if (nodes.length >= 2) {
      var xs = nodes.map(function(n) { return n.x; });
      var x0 = Math.min.apply(null, xs) - 20, x1 = Math.max.apply(null, xs) + 20;
      ctx.globalAlpha = ease * 0.15;
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 1; ctx.setLineDash([4, 6]);
      ctx.beginPath(); ctx.moveTo(x0, H * 0.42); ctx.lineTo(x1, H * 0.42); ctx.stroke();
      ctx.setLineDash([]);
    }

    /* Source dots */
    nodes.forEach(function(n, i) {
      var startAt = (i / totalDots) * 0.45;
      var dotP = Math.max(0, Math.min(1, (progress - startAt) / (1 - startAt)));
      if (dotP === 0) return;
      var pulse = 0.78 + 0.22 * Math.sin(t * 1.3 + n.phase);
      /* Glow */
      var grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, 26);
      grd.addColorStop(0, n.color + 'AA'); grd.addColorStop(1, n.color + '00');
      ctx.globalAlpha = 0.5 * dotP * pulse; ctx.fillStyle = grd;
      ctx.beginPath(); ctx.arc(n.x, n.y, 26, 0, Math.PI * 2); ctx.fill();
      /* Core */
      ctx.globalAlpha = dotP * pulse; ctx.fillStyle = n.color;
      ctx.beginPath(); ctx.arc(n.x, n.y, 11, 0, Math.PI * 2); ctx.fill();
      /* Label */
      if (dotP > 0.7) {
        var a = (dotP - 0.7) / 0.3;
        ctx.globalAlpha = a * 0.85; ctx.fillStyle = n.color;
        ctx.font = "bold 10px 'Space Grotesk'"; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.fillText(n.source, n.x, n.y + 15);
      }
    });

    /* Spectrum labels */
    if (ease > 0.7) {
      var a = (ease - 0.7) / 0.3;
      ctx.globalAlpha = a * 0.3; ctx.fillStyle = '#F0F0F5';
      ctx.font = "bold 9px 'Space Mono'"; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('NATIONAL', 16, H * 0.92);
      ctx.textAlign = 'right';
      ctx.fillText('SPECIALIST', W - 16, H * 0.92);
    }
    ctx.globalAlpha = 1; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    rAF(draw);
  }

  /* Replay on scroll into view */
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        build();
        progress = 0;
        nodes.forEach(function(n) { n.x = W / 2; n.y = H / 2; });
        started = true;
        rAF(draw);
      }
    });
  }, { threshold: 0.2 });
  io.observe(canvas.closest('.diverge-sec'));
  window.addEventListener('resize', function() { if (started) { build(); progress = 0; } });

  /* Tooltip */
  canvas.addEventListener('mousemove', function(e) {
    var rect = canvas.getBoundingClientRect();
    var mx = (e.clientX - rect.left) * (W / rect.width);
    var my = (e.clientY - rect.top) * (H / rect.height);
    var hit = null;
    for (var i = 0; i < nodes.length; i++) {
      if (Math.hypot(mx - nodes[i].x, my - nodes[i].y) < 18) { hit = nodes[i]; break; }
    }
    if (hit) {
      tip.style.display = 'block';
      tip.style.left = (e.clientX + 14) + 'px'; tip.style.top = (e.clientY - 8) + 'px';
      tip.innerHTML = '<div class="tt-name" style="color:' + hit.color + '">' + hit.source + '</div>' +
        '<div class="tt-meta">' + (hit.tier || '') + '</div>' +
        (hit.title ? '<div class="tt-text">"' + hit.title + '"</div>' : '');
    } else {
      tip.style.display = 'none';
    }
  });
  canvas.addEventListener('mouseleave', function() { tip.style.display = 'none'; });
}


/* ─── NAV scroll state ─── */
function initNav() {
  var nav = document.querySelector('.nav');
  if (nav) {
    window.addEventListener('scroll', function() {
      nav.classList.toggle('solid', window.scrollY > 80);
    }, { passive: true });
  }
}
</script>

