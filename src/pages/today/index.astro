  return GEO_MAP[sourceName] || null;
}

---

<BaseLayout title={`${(editorial?.accessible_headline || editorial?.headline || 'Today').slice(0, 55)} | Signal Board`} description={editorial?.subheadline || `Daily analysis from 300 sources across borders, languages, and political orientations.`} dateStr={dateStr} totalStories={totalStories} sourcesReporting={sourcesReporting}>

<!-- MASTHEAD — NAVY -->
<header class="masthead-wrap" role="banner">
  <!-- Decorative constellation — represents interconnected sources -->
  <svg class="masthead-constellation" viewBox="0 0 800 600" fill="none" aria-hidden="true" style="position: absolute; top: 0; right: 0; width: 55%; height: 100%; opacity: 0.14; pointer-events: none;">
    <!-- Connection lines -->
    <line x1="120" y1="80" x2="340" y2="160" stroke="#42F0A5" stroke-width="1" opacity="0.8"/>
    <line x1="340" y1="160" x2="580" y2="120" stroke="#1B2A4B" stroke-width="1" opacity="0.6"/>
    <line x1="580" y1="120" x2="700" y2="280" stroke="#F87575" stroke-width="1" opacity="0.7"/>
    <line x1="340" y1="160" x2="260" y2="340" stroke="#FDB833" stroke-width="1" opacity="0.5"/>
    <line x1="260" y1="340" x2="480" y2="380" stroke="#1789FC" stroke-width="1" opacity="0.6"/>
    <line x1="480" y1="380" x2="700" y2="280" stroke="#42F0A5" stroke-width="1" opacity="0.4"/>
    <line x1="480" y1="380" x2="620" y2="500" stroke="#F87575" stroke-width="1" opacity="0.5"/>
    <line x1="260" y1="340" x2="140" y2="480" stroke="#1789FC" stroke-width="1" opacity="0.3"/>
    <line x1="140" y1="480" x2="380" y2="520" stroke="#FDB833" stroke-width="1" opacity="0.4"/>
    <line x1="380" y1="520" x2="620" y2="500" stroke="#42F0A5" stroke-width="1" opacity="0.5"/>
    <line x1="580" y1="120" x2="480" y2="380" stroke="#1B2A4B" stroke-width="0.5" opacity="0.3"/>
    <line x1="120" y1="80" x2="260" y2="340" stroke="#F87575" stroke-width="0.5" opacity="0.4"/>
    <!-- Nodes — sources -->
    <circle cx="120" cy="80" r="4" fill="#F87575" opacity="0.7"/>
    <circle cx="340" cy="160" r="6" fill="#42F0A5" opacity="0.6"/>
    <circle cx="580" cy="120" r="5" fill="#1789FC" opacity="0.5"/>
    <circle cx="700" cy="280" r="4" fill="#F87575" opacity="0.6"/>
    <circle cx="260" cy="340" r="7" fill="#FDB833" opacity="0.5"/>
    <circle cx="480" cy="380" r="5" fill="#42F0A5" opacity="0.4"/>
    <circle cx="620" cy="500" r="4" fill="#1789FC" opacity="0.5"/>
    <circle cx="140" cy="480" r="3" fill="#F87575" opacity="0.4"/>
    <circle cx="380" cy="520" r="5" fill="#FDB833" opacity="0.4"/>
    <!-- Smaller orbiting dots -->
    <circle cx="200" cy="110" r="2" fill="#42F0A5" opacity="0.3"/>
    <circle cx="460" cy="140" r="2" fill="#1789FC" opacity="0.2"/>
    <circle cx="640" cy="200" r="2" fill="#F87575" opacity="0.3"/>
    <circle cx="360" cy="260" r="2" fill="#FDB833" opacity="0.2"/>
    <circle cx="540" cy="440" r="2" fill="#42F0A5" opacity="0.25"/>
    <circle cx="200" cy="420" r="2" fill="#1789FC" opacity="0.2"/>
  </svg>
  <div class="wrap" style="position: relative; z-index: 1;">
    <nav aria-label="Signal Board navigation" style="padding-top: 24px; display: flex; justify-content: flex-end; gap: 24px;">
      <a href="/about/" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">About</a>
      <a href="/archive/" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">Archive</a>
      <a href="https://substack.com/@elisehasseltine" target="_blank" rel="noopener" style="font-family: 'Inter', sans-serif; font-size: 13px; color: var(--on-navy-dim); text-decoration: none; transition: color 0.2s;">Subscribe</a>
    </nav>
    <div class="masthead">
      <div class="r">
        <div class="display masthead-title">SIGNAL</div>
        <div class="display masthead-title">BOARD</div>
