  };
  return SOURCE_CONTEXT[sourceName] || null;
}

function tierLabel(tier: string): string {
  const labels: Record<string, string> = {
    'national': 'National',
    'international': 'International',
    'local-regional': 'Local & Regional',
    'specialist': 'Specialist',
    'analysis': 'Analysis',
    'explainer': 'Explainer',
    'newsletter': 'Newsletter',
    'research': 'Research',
  };
  return labels[tier] || tier;
}

function getSourceGeo(sourceName: string): { country: string; geo: string; tier: string } | null {
  const GEO_MAP: Record<string, { country: string; geo: string; tier: string }> = {
    'Dawn': { country: 'PK', geo: 'international', tier: 'international' },
    'Rappler': { country: 'PH', geo: 'international', tier: 'international' },
    'South China Morning Post': { country: 'HK', geo: 'international', tier: 'international' },
    'Times of India': { country: 'IN', geo: 'international', tier: 'international' },
    'Straits Times': { country: 'SG', geo: 'international', tier: 'international' },
    'BBC World': { country: 'UK', geo: 'international', tier: 'international' },
    'NHK World': { country: 'JP', geo: 'international', tier: 'international' },
